---
import Layout from '../layouts/Layout.astro';
---

<Layout activeTab="matrix">
  <div class="w-full max-w-2xl mx-auto space-y-6">
    <!-- Page Header -->
    <div class="text-center md:text-left space-y-1.5 border-b border-brand-border/60 pb-4">
      <div class="text-[10px] font-mono uppercase tracking-widest text-brand-blue-neon">
        System Mode: Linear Algebra
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-brand-text">
        Matrix Computational Suite<span class="text-brand-blue">.</span>
      </h1>
      <p class="text-xs text-brand-text-muted">
        Perform vector-matrix algebra, transpose, compute determinants, and compute inverses with full precision rounding.
      </p>
    </div>

    <!-- Live Status -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-1 sm:gap-2 px-3 py-1.5 bg-brand-gray-light/40 border border-brand-border rounded text-[10px] font-mono text-brand-text-muted">
      <div>MATRIX A Dimensions: <span id="dim-a-display">3x3</span></div>
      <div>MATRIX B Dimensions: <span id="dim-b-display">3x3</span></div>
    </div>

    <!-- Matrix Configuration & Inputs -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6">
      <!-- Matrix A Card -->
      <div class="border border-brand-border bg-brand-gray-dark/40 rounded-xl p-4 sm:p-5 space-y-3 sm:space-y-4">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-2">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-brand-text light:text-neutral-500 font-mono">Matrix A</h2>
          <div class="flex space-x-1">
            <button class="dim-btn-a px-2.5 py-1 text-[10px] border border-brand-border rounded font-mono hover:bg-brand-gray-hover min-h-[40px]" data-dim="2">2x2</button>
            <button class="dim-btn-a px-2.5 py-1 text-[10px] border border-brand-blue bg-brand-gray-hover text-brand-text light:text-neutral-600 rounded font-mono min-h-[40px]" data-dim="3">3x3</button>
          </div>
        </div>

        <!-- Matrix A Grid -->
        <div id="grid-a" class="grid gap-1.5 sm:gap-2 py-2">
          <!-- Dynamic Input Cells -->
        </div>

        <!-- A Operations -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-2">
          <button class="op-btn-matrix text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-text-muted hover:text-white min-h-[40px]" data-op="det-a">Determinant</button>
          <button class="op-btn-matrix text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-text-muted hover:text-white min-h-[40px]" data-op="inv-a">Inverse</button>
          <button class="op-btn-matrix text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-text-muted hover:text-white sm:col-span-2 min-h-[40px]" data-op="trans-a">Transpose</button>
        </div>
      </div>

      <!-- Matrix B Card -->
      <div class="border border-brand-border bg-brand-gray-dark/40 rounded-xl p-4 sm:p-5 space-y-3 sm:space-y-4">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-2">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-brand-text light:text-neutral-500 font-mono">Matrix B</h2>
          <div class="flex space-x-1">
            <button class="dim-btn-b px-2.5 py-1 text-[10px] border border-brand-border rounded font-mono hover:bg-brand-gray-hover min-h-[40px]" data-dim="2">2x2</button>
            <button class="dim-btn-b px-2.5 py-1 text-[10px] border border-brand-blue bg-brand-gray-hover text-brand-text light:text-neutral-600 rounded font-mono min-h-[40px]" data-dim="3">3x3</button>
          </div>
        </div>

        <!-- Matrix B Grid -->
        <div id="grid-b" class="grid gap-1.5 sm:gap-2 py-2">
          <!-- Dynamic Input Cells -->
        </div>

        <!-- B Operations -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-2">
          <button class="op-btn-matrix text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-text-muted hover:text-white min-h-[40px]" data-op="det-b">Determinant</button>
          <button class="op-btn-matrix text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-text-muted hover:text-white min-h-[40px]" data-op="inv-b">Inverse</button>
          <button class="op-btn-matrix text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-text-muted hover:text-white sm:col-span-2 min-h-[40px]" data-op="trans-b">Transpose</button>
        </div>
      </div>
    </div>

    <!-- Dual Matrix Joint Operations -->
    <div class="border border-brand-border bg-brand-gray-dark/30 rounded-xl p-3 sm:p-4 flex flex-col sm:flex-row flex-wrap gap-2 sm:gap-3 justify-center items-center">
      <span class="text-xs font-mono text-brand-text-muted px-2">Binary Operations:</span>
      <button class="op-btn-matrix px-3 py-2 text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover hover:border-brand-border-hover text-brand-blue-neon font-semibold min-h-[40px] flex-1 sm:flex-initial" data-op="add">A + B</button>
      <button class="op-btn-matrix px-3 py-2 text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover hover:border-brand-border-hover text-brand-blue-neon font-semibold min-h-[40px] flex-1 sm:flex-initial" data-op="sub">A - B</button>
      <button class="op-btn-matrix px-3 py-2 text-xs sm:text-sm border border-brand-border bg-brand-black hover:bg-brand-gray-hover hover:border-brand-border-hover text-brand-blue-neon font-semibold min-h-[40px] flex-1 sm:flex-initial" data-op="mul">A &times; B (Product)</button>
    </div>

    <!-- Viewport Result Console -->
    <div class="border border-brand-border bg-brand-black rounded-xl p-6 space-y-4">
      <div class="flex items-center justify-between border-b border-brand-border/60 pb-2">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-brand-text-muted font-mono flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-blue"></span> Output Console
        </h3>
        <div id="output-operation" class="text-[10px] font-mono text-brand-blue-neon uppercase">Ready</div>
      </div>

      <div id="console-display" class="flex flex-col items-center justify-center min-h-[120px] text-center font-mono">
        <span class="text-brand-text-dim text-xs">Awaiting calculation input...</span>
      </div>
    </div>

    <!-- SEO Educational Documentation Block -->
    <section class="border border-brand-border bg-brand-gray-dark/20 rounded-xl p-6 sm:p-8 space-y-6 text-brand-text-muted leading-relaxed text-sm">
      <div class="border-b border-brand-border pb-3">
        <h2 class="text-lg font-bold tracking-tight text-white flex items-center gap-2">
          <span class="text-brand-blue-neon font-mono">#</span> Linear Algebra & Matrix Math Handbook
        </h2>
      </div>

      <div class="space-y-4">
        <h3 class="text-base font-semibold text-white tracking-tight">### How to Calculate a 3x3 Matrix Determinant</h3>
        <p>
          The determinant of a 3x3 matrix is a fundamental scalar value that characterizes the matrix's algebraic and geometric properties. Geometrically, the absolute value of the determinant measures the signed volume of a parallelepiped spanned by the three-dimensional vectors representing the matrix's rows or columns. Calculating this value is essential for verifying whether a system of linear equations possesses a unique solution, determining matrix invertibility, and performing change-of-variable coordinate transformations in multi-variable calculus.
        </p>
        <p>
          To compute the determinant of a 3x3 matrix A using Laplace's formula of expansion by cofactors along the first row, we define the matrix coefficients as follows:
        </p>
        <div class="bg-brand-black/50 border border-brand-border p-4 rounded-lg font-mono text-xs text-center text-brand-text overflow-x-auto">
          A = [ [a, b, c], [d, e, f], [g, h, i] ]
        </div>
        <p>
          The algebraic formula is represented by: <code class="font-mono text-brand-blue-neon font-semibold bg-brand-black px-1.5 py-0.5 rounded">det(A) = a(ei - fh) - b(di - fg) + c(dh - eg)</code>. In this method, the calculation is decomposed into three smaller 2x2 determinants, called minors, which are multiplied by the corresponding elements from the first row and adjusted with alternating signs (+, -, +). For example, the minor for coefficient 'a' is the determinant of the 2x2 matrix remaining after removing the first row and the first column, which yields \( (e \cdot i - f \cdot h) \). Summing these terms yields the overall determinant. If the determinant equals zero, the matrix is singular, meaning its columns are linearly dependent and it cannot be inverted. Additionally, in computer science and numerical computing, alternative algorithms like Gaussian elimination with partial pivoting or LU decomposition are preferred for matrices of larger dimensions. These algorithms scale with a time complexity of \( O(n^3) \), which is far more efficient than cofactor expansion (which scales factorially as \( O(n!) \)) for large-scale engineering applications.
        </p>
      </div>

      <!-- DSA Guide Affiliate Recommendation Box -->
      <div class="p-4 sm:p-5 rounded-xl border border-brand-border bg-brand-gray-light/60 backdrop-blur-sm flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 hover:border-brand-border-strong transition-colors duration-200">
        <div class="space-y-1">
          <div class="text-[10px] font-mono uppercase tracking-wider text-brand-blue-neon">Student Resource Recommendation</div>
          <h4 class="text-sm font-semibold text-white">Data Structures and Algorithms (DSA) Master Guide</h4>
          <p class="text-xs text-brand-text-muted">Master advanced matrix representations, graphs, and optimization algorithms essential for top-tier software engineering interviews.</p>
        </div>
        <a 
          href="https://scicalcx.com/affiliate-dsa" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="shrink-0 text-xs font-mono font-semibold px-4 py-2.5 rounded border border-brand-blue-neon/40 hover:border-brand-blue-neon bg-brand-blue/10 hover:bg-brand-blue text-brand-blue-neon hover:text-white transition-all duration-200"
        >
          Get Guide &rarr;
        </a>
      </div>

      <div class="space-y-4">
        <h3 class="text-base font-semibold text-white tracking-tight">### Step-by-Step Matrix Inversion Method</h3>
        <p>
          Matrix inversion is the process of identifying a unique square matrix, denoted as \( A^&#123;-1&#125; \), such that its product with the original matrix \( A \) yields the identity matrix: \( A \cdot A^&#123;-1&#125; = A^&#123;-1&#125; \cdot A = I \). To invert a 3x3 matrix analytically, the adjugate method is highly popular because it provides an explicit formula based on determinants.
        </p>
        <p>
          The step-by-step algorithm is as follows: First, calculate the determinant of the matrix \( A \). If the determinant is exactly zero, the matrix is singular and the inverse does not exist. Second, find the matrix of minors by computing the 2x2 determinant for each of the nine elements. Third, convert this matrix of minors into the cofactor matrix by applying alternating signs according to the checkerboard rule where \( C_&#123;ij&#125; = (-1)^&#123;i+j&#125; M_&#123;ij&#125; \). Fourth, transpose the cofactor matrix to obtain the adjugate matrix, \( \text&#123;adj&#125;(A) = C^T \), which swaps elements across the main diagonal. Finally, divide every element of the adjugate matrix by the determinant of \( A \): <code class="font-mono text-brand-blue-neon font-semibold bg-brand-black px-1.5 py-0.5 rounded">A^-1 = adj(A) / det(A)</code>. This numerical recipe ensures precise, deterministic solutions for low-dimensional computational systems, whereas higher-dimensional matrix inversions in engineering systems typically leverage factorization strategies to maintain numerical stability and avoid computational overflow.
        </p>
      </div>
    </section>
  </div>

  <style>
    button {
      outline: none;
    }
    .op-btn-matrix {
      height: 40px;
      min-height: 40px;
      border-radius: 6px;
      transition: all 0.15s ease-in-out;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .dim-btn-a, .dim-btn-b {
      min-height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cell-a, .cell-b {
      min-height: 44px;
      font-size: 0.875rem;
    }
    @media (max-width: 639px) {
      .cell-a, .cell-b {
        font-size: 1rem;
        padding: 0.75rem 0.5rem;
      }
    }
  </style>

  <script>
    let dimA = 3;
    let dimB = 3;

    // Helper: Precision rounding for float calculations
    function clean(val: number) {
      if (isNaN(val) || !isFinite(val)) return val;
      return Number(val.toPrecision(12));
    }

    // Dynamic grid builders
    function buildGrid(matrixName: 'a' | 'b', dim: number) {
      const grid = document.getElementById(`grid-${matrixName}`)!;
      grid.className = `grid gap-1.5 py-2 ${dim === 2 ? 'grid-cols-2' : 'grid-cols-3'}`;
      
      let html = '';
      for (let r = 0; r < dim; r++) {
        for (let c = 0; c < dim; c++) {
          const val = (r === c) ? '1' : '0'; // Default identity matrix helper
          html += `
            <input 
              type="number" 
              step="any" 
              class="cell-${matrixName} bg-brand-black hover:border-brand-border-hover focus:border-brand-blue border border-brand-border rounded text-white font-mono text-center text-sm sm:text-base focus:outline-none focus:ring-1 focus:ring-brand-blue/30 min-h-[44px]"
              data-row="${r}" 
              data-col="${c}" 
              value="${val}" 
              placeholder="0"
            />
          `;
        }
      }
      grid.innerHTML = html;
    }

    // Retrieve matrix values as multi-dimensional array
    function getMatrixValues(matrixName: 'a' | 'b', dim: number): number[][] {
      const inputs = document.querySelectorAll(`.cell-${matrixName}`) as NodeListOf<HTMLInputElement>;
      const matrix: number[][] = Array.from({ length: dim }, () => Array(dim).fill(0));
      
      inputs.forEach(input => {
        const row = parseInt(input.getAttribute('data-row')!);
        const col = parseInt(input.getAttribute('data-col')!);
        const val = parseFloat(input.value);
        matrix[row][col] = isNaN(val) ? 0 : val;
      });
      return matrix;
    }

    // Format matrix output helper to match input grid structures
    function renderMatrixHtml(matrix: number[][]): string {
      const rows = matrix.length;
      const cols = matrix[0].length;
      let gridStyles = rows === 2 ? 'grid-cols-2' : 'grid-cols-3';

      let cellsHtml = matrix
        .map(row => 
          row.map(val => `<input type="text" class="bg-brand-black/40 border border-brand-border rounded text-brand-text font-mono text-center text-sm sm:text-base focus:outline-none min-w-[64px] min-h-[44px]" value="${clean(val)}" readonly />`).join('')
        )
        .join('');

      return `
        <div class="grid gap-2 ${gridStyles} max-w-[240px] mx-auto p-4 bg-brand-gray-dark/30 border border-brand-border rounded-xl">
          ${cellsHtml}
        </div>
      `;
    }

    // Det calculation (2x2 & 3x3)
    function calcDet(m: number[][]): number {
      if (m.length === 2) {
        return m[0][0] * m[1][1] - m[0][1] * m[1][0];
      } else {
        return (
          m[0][0] * (m[1][1] * m[2][2] - m[1][2] * m[2][1]) -
          m[0][1] * (m[1][0] * m[2][2] - m[1][2] * m[2][0]) +
          m[0][2] * (m[1][0] * m[2][1] - m[1][1] * m[2][0])
        );
      }
    }

    // Transpose calculation
    function calcTranspose(m: number[][]): number[][] {
      const dim = m.length;
      const result = Array.from({ length: dim }, () => Array(dim).fill(0));
      for (let r = 0; r < dim; r++) {
        for (let c = 0; c < dim; c++) {
          result[c][r] = m[r][c];
        }
      }
      return result;
    }

    // Inverse calculation
    function calcInverse(m: number[][]): number[][] | null {
      const det = calcDet(m);
      if (Math.abs(det) < 1e-12) return null; // Non-invertible

      const dim = m.length;
      if (dim === 2) {
        return [
          [m[1][1] / det, -m[0][1] / det],
          [-m[1][0] / det, m[0][0] / det]
        ];
      } else {
        const result = Array.from({ length: 3 }, () => Array(3).fill(0));
        // Adjugate calculation
        result[0][0] = (m[1][1] * m[2][2] - m[1][2] * m[2][1]) / det;
        result[0][1] = -(m[0][1] * m[2][2] - m[0][2] * m[2][1]) / det;
        result[0][2] = (m[0][1] * m[1][2] - m[0][2] * m[1][1]) / det;

        result[1][0] = -(m[1][0] * m[2][2] - m[1][2] * m[2][0]) / det;
        result[1][1] = (m[0][0] * m[2][2] - m[0][2] * m[2][0]) / det;
        result[1][2] = -(m[0][0] * m[1][2] - m[0][2] * m[1][0]) / det;

        result[2][0] = (m[1][0] * m[2][1] - m[1][1] * m[2][0]) / det;
        result[2][1] = -(m[0][0] * m[2][1] - m[0][1] * m[2][0]) / det;
        result[2][2] = (m[0][0] * m[1][1] - m[0][1] * m[1][0]) / det;

        return result;
      }
    }

    // Handle operations
    const consoleDisplay = document.getElementById('console-display')!;
    const outputOperation = document.getElementById('output-operation')!;

    function handleMatrixOp(op: string) {
      const mDecA = getMatrixValues('a', dimA);
      const mDecB = getMatrixValues('b', dimB);

      try {
        if (op === 'det-a') {
          const val = calcDet(mDecA);
          const formatted = String(clean(val));
          outputOperation.textContent = 'Det(A)';
          consoleDisplay.innerHTML = `<div class="text-xl font-bold text-white">Determinant of A = ${formatted}</div>`;
          saveToHistory(`Det(A)`, formatted);
        } else if (op === 'det-b') {
          const val = calcDet(mDecB);
          const formatted = String(clean(val));
          outputOperation.textContent = 'Det(B)';
          consoleDisplay.innerHTML = `<div class="text-xl font-bold text-white">Determinant of B = ${formatted}</div>`;
          saveToHistory(`Det(B)`, formatted);
        } else if (op === 'trans-a') {
          const trans = calcTranspose(mDecA);
          outputOperation.textContent = 'A^T';
          consoleDisplay.innerHTML = renderMatrixHtml(trans);
          saveToHistory(`Transpose(A)`, JSON.stringify(trans));
        } else if (op === 'trans-b') {
          const trans = calcTranspose(mDecB);
          outputOperation.textContent = 'B^T';
          consoleDisplay.innerHTML = renderMatrixHtml(trans);
          saveToHistory(`Transpose(B)`, JSON.stringify(trans));
        } else if (op === 'inv-a') {
          const inv = calcInverse(mDecA);
          outputOperation.textContent = 'A^-1';
          if (!inv) {
            consoleDisplay.innerHTML = `<span class="text-red-500 font-semibold text-xs">Error: Matrix is singular (determinant is 0). Inverse does not exist.</span>`;
          } else {
            consoleDisplay.innerHTML = renderMatrixHtml(inv);
            saveToHistory(`Inverse(A)`, JSON.stringify(inv));
          }
        } else if (op === 'inv-b') {
          const inv = calcInverse(mDecB);
          outputOperation.textContent = 'B^-1';
          if (!inv) {
            consoleDisplay.innerHTML = `<span class="text-red-500 font-semibold text-xs">Error: Matrix is singular (determinant is 0). Inverse does not exist.</span>`;
          } else {
            consoleDisplay.innerHTML = renderMatrixHtml(inv);
            saveToHistory(`Inverse(B)`, JSON.stringify(inv));
          }
        } else if (op === 'add') {
          if (dimA !== dimB) {
            consoleDisplay.innerHTML = `<span class="text-red-500 text-xs">Dimension Error: Matrices must share matching dimensions.</span>`;
            return;
          }
          const res = mDecA.map((row, r) => row.map((val, c) => val + mDecB[r][c]));
          outputOperation.textContent = 'A + B';
          consoleDisplay.innerHTML = renderMatrixHtml(res);
          saveToHistory(`A + B`, JSON.stringify(res));
        } else if (op === 'sub') {
          if (dimA !== dimB) {
            consoleDisplay.innerHTML = `<span class="text-red-500 text-xs">Dimension Error: Matrices must share matching dimensions.</span>`;
            return;
          }
          const res = mDecA.map((row, r) => row.map((val, c) => val - mDecB[r][c]));
          outputOperation.textContent = 'A - B';
          consoleDisplay.innerHTML = renderMatrixHtml(res);
          saveToHistory(`A - B`, JSON.stringify(res));
        } else if (op === 'mul') {
          if (dimA !== dimB) {
            consoleDisplay.innerHTML = `<span class="text-red-500 text-xs">Dimension Error: Matrices must share matching dimensions.</span>`;
            return;
          }
          const dim = dimA;
          const res = Array.from({ length: dim }, () => Array(dim).fill(0));
          for (let r = 0; r < dim; r++) {
            for (let c = 0; c < dim; c++) {
              let sum = 0;
              for (let k = 0; k < dim; k++) {
                sum += mDecA[r][k] * mDecB[k][c];
              }
              res[r][c] = sum;
            }
          }
          outputOperation.textContent = 'A * B';
          consoleDisplay.innerHTML = renderMatrixHtml(res);
          saveToHistory(`A * B`, JSON.stringify(res));
        }
      } catch (err: any) {
        consoleDisplay.innerHTML = `<span class="text-red-500 text-xs">Evaluation Error: ${err.message}</span>`;
      }
    }

    // History sync helper
    function saveToHistory(expr: string, result: string) {
      window.dispatchEvent(
        new CustomEvent('add-history', {
          detail: { expr, result, mode: 'matrix' }
        })
      );
    }

    // Dynamic configuration hooks
    function initDimensionListeners() {
      // Dimensions A
      document.querySelectorAll('.dim-btn-a').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.dim-btn-a').forEach(b => b.classList.replace('border-brand-blue', 'border-brand-border'));
          document.querySelectorAll('.dim-btn-a').forEach(b => b.classList.remove('bg-brand-gray-hover', 'text-white'));
          btn.classList.replace('border-brand-border', 'border-brand-blue');
          btn.classList.add('bg-brand-gray-hover', 'text-white');
          
          dimA = parseInt(btn.getAttribute('data-dim')!);
          document.getElementById('dim-a-display')!.textContent = `${dimA}x${dimA}`;
          buildGrid('a', dimA);
        });
      });

      // Dimensions B
      document.querySelectorAll('.dim-btn-b').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.dim-btn-b').forEach(b => b.classList.replace('border-brand-blue', 'border-brand-border'));
          document.querySelectorAll('.dim-btn-b').forEach(b => b.classList.remove('bg-brand-gray-hover', 'text-white'));
          btn.classList.replace('border-brand-border', 'border-brand-blue');
          btn.classList.add('bg-brand-gray-hover', 'text-white');
          
          dimB = parseInt(btn.getAttribute('data-dim')!);
          document.getElementById('dim-b-display')!.textContent = `${dimB}x${dimB}`;
          buildGrid('b', dimB);
        });
      });

      // Ops handlers
      document.querySelectorAll('.op-btn-matrix').forEach(btn => {
        btn.addEventListener('click', () => {
          const op = btn.getAttribute('data-op')!;
          handleMatrixOp(op);
        });
      });
    }

    // Populate initial inputs from history triggers
    window.addEventListener('load-expression', (e: any) => {
      if (e.detail.mode === 'matrix') {
        const expr = e.detail.expression;
        const resStr = e.detail.result;
        outputOperation.textContent = expr;
        
        try {
          const parsed = JSON.parse(resStr);
          if (Array.isArray(parsed) && Array.isArray(parsed[0])) {
            consoleDisplay.innerHTML = renderMatrixHtml(parsed);
          } else {
            consoleDisplay.innerHTML = `<div class="text-xl font-bold text-brand-text">${resStr}</div>`;
          }
        } catch {
          consoleDisplay.innerHTML = `<div class="text-xl font-bold text-brand-text">${resStr}</div>`;
        }
      }
    });

    // Run builders
    buildGrid('a', 3);
    buildGrid('b', 3);
    initDimensionListeners();
  </script>
</Layout>

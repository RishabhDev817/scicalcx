---
import Layout from '../layouts/Layout.astro';
---

<Layout activeTab="scientific">
  <div class="w-full max-w-2xl mx-auto space-y-4 sm:space-y-6">
    <!-- Page Header and Eyebrow -->
    <div class="text-center md:text-left space-y-1.5 border-b border-brand-border/60 pb-3 sm:pb-4">
      <div class="text-[9px] sm:text-[10px] font-mono uppercase tracking-widest text-brand-blue-neon">
        System Mode: Core Compute
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-brand-text">
        Scientific Calculator<span class="text-brand-blue">.</span>
      </h1>
    </div>

    <!-- Live Engine Status Bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-2 px-3 py-1.5 bg-brand-gray-light/40 border border-brand-border rounded text-[9px] sm:text-[10px] font-mono text-brand-text-muted">
      <div class="flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span>ENGINE STATUS: ACTIVE</span>
        <span id="memory-indicator" class="hidden ml-2 px-1.5 py-0.5 bg-brand-blue/10 border border-brand-blue/30 text-brand-blue-neon rounded text-[8px] font-bold tracking-wider animate-pulse">
          M
        </span>
      </div>
      <div class="flex items-center gap-2 sm:gap-4">
        <span class="hidden sm:inline">PRECISION: FLOAT64 (12-DEC)</span>
        <!-- Sleek DEG/RAD slider toggle capsule -->
        <div class="relative flex items-center bg-brand-black border border-neutral-800 light:border-neutral-300 rounded-full p-0.5 select-none w-24 h-6">
          <div 
            id="angle-slider" 
            class="absolute top-0.5 bottom-0.5 left-0.5 w-[44px] bg-brand-text rounded-full transition-transform duration-200 ease-in-out"
            style="transform: translateX(44px);"
          ></div>
          <button 
            id="toggle-deg" 
            type="button"
            class="relative z-10 flex-1 text-center text-[9px] font-bold font-mono tracking-wider transition-colors duration-200 focus:outline-none cursor-pointer text-brand-text-muted"
          >
            DEG
          </button>
          <button 
            id="toggle-rad" 
            type="button"
            class="relative z-10 flex-1 text-center text-[9px] font-bold font-mono tracking-wider transition-colors duration-200 focus:outline-none cursor-pointer text-brand-black"
          >
            RAD
          </button>
        </div>
      </div>
    </div>

    <!-- Main Calculator Interface -->
    <div class="border border-brand-border bg-brand-gray-dark/40 rounded-xl p-3 sm:p-5 space-y-3 sm:space-y-4 shadow-xl backdrop-blur-sm relative overflow-hidden">
      <!-- Hidden Input for Native Keyboard Interaction -->
      <input 
        type="text" 
        id="raw-input" 
        class="sr-only" 
        autocomplete="off" 
        autocorrect="off" 
        autocapitalize="off" 
        spellcheck="false"
        autofocus
      />

      <!-- Auto-Wrapping Multi-Line Viewport Display -->
      <div 
        id="display-container" 
        class="w-full min-h-[80px] sm:min-h-[96px] bg-brand-black border border-brand-border rounded-lg p-3 sm:p-4 flex flex-col justify-between cursor-text hover:border-brand-border-hover transition-colors focus-within:border-brand-blue focus-within:ring-1 focus-within:ring-brand-blue"
        tabindex="0"
      >
        <!-- Token Matcher Syntax Overlay -->
        <div id="display-tokens" class="w-full text-sm sm:text-base sm:text-lg font-mono break-all whitespace-pre-wrap text-brand-text-muted min-h-[24px] sm:min-h-[28px] leading-relaxed">
          <span class="text-brand-text-dim italic">Type or press keys to calculate...</span>
        </div>

        <!-- Result / Error Real-time Preview Pane -->
        <div class="flex items-end justify-between mt-2 sm:mt-3 pt-2 border-t border-brand-border/30">
          <div id="bracket-validation" class="text-[9px] sm:text-[10px] font-mono text-brand-text-dim">
            <!-- Bracket validation state -->
          </div>
          <div id="display-result" class="text-xl sm:text-2xl sm:text-3xl font-bold font-mono text-brand-text tracking-tight break-all">
            0
          </div>
        </div>
      </div>

      <!-- Middle Scientific Functions Block -->
      <div class="grid grid-cols-3 sm:grid-cols-6 gap-1.5 sm:gap-2">
        <!-- Row 1 -->
        <button class="key-sci font-bold animate-pulse" data-key="shift" id="btn-shift">SHIFT</button>
        <button class="key-sci font-serif text-sm" data-key="/">◼/◼</button>
        <button class="key-sci text-xs" data-key="logBase">log_◼(◻)</button>
        <button class="key-sci text-sm" data-key="sqrt">√◼</button>
        <button class="key-sci text-sm" data-key="sqr">x²</button>
        <button class="key-sci text-sm" data-key="^">x^◼</button>

        <!-- Row 2 -->
        <button class="key-sci text-sm" data-key="log">log</button>
        <button class="key-sci text-sm" data-key="ln">ln</button>
        <button class="key-sci text-sm" data-key="hyp" id="btn-hyp">hyp</button>
        <button class="key-sci text-sm" data-key="sin" id="btn-sin">sin</button>
        <button class="key-sci" data-key="cos" id="btn-cos">cos</button>
        <button class="key-sci" data-key="tan" id="btn-tan">tan</button>

        <!-- Row 3 -->
        <button class="key-sci text-sm" data-key="(">(</button>
        <button class="key-sci text-sm" data-key=")" id="btn-paren-close">)</button>
        <button class="key-sci text-xs" data-key="DMS">° ' ''</button>
        <button class="key-sci text-xs" data-key="SD">S⇔D</button>
        <button class="key-sci" data-key="pi">π</button>
        <button class="key-sci" data-key="e">e</button>
      </div>

      <!-- Divider between zones -->
      <div class="border-t border-brand-border/30 my-2 sm:my-3"></div>

      <!-- Absolute Bottom Number Block -->
      <div class="grid grid-cols-5 gap-1.5 sm:gap-2">
        <!-- Row 0: Clears -->
        <div class="col-span-3"></div>
        <button class="key-cmd font-bold" data-key="backspace">DEL</button>
        <button class="key-cmd font-bold" data-key="clear">AC</button>

        <!-- Row 1: 7-9 & Sub/Div -->
        <button class="key-num" data-key="7">7</button>
        <button class="key-num" data-key="8">8</button>
        <button class="key-num" data-key="9">9</button>
        <button class="key-op" data-key="-">-</button>
        <button class="key-op" data-key="/" id="btn-div">/</button>

        <!-- Row 2: 4-6 & Memory/Mult -->
        <button class="key-num" data-key="4">4</button>
        <button class="key-num" data-key="5">5</button>
        <button class="key-num" data-key="6">6</button>
        <button class="key-sci text-sm" data-key="MR" id="btn-mr">MR</button>
        <button class="key-op" data-key="*" id="btn-mult">*</button>

        <!-- Row 3: 1-3 & Memory/Add -->
        <button class="key-num" data-key="1">1</button>
        <button class="key-num" data-key="2">2</button>
        <button class="key-num" data-key="3">3</button>
        <button class="key-sci text-sm" data-key="M+" id="btn-mplus">M+</button>
        <button class="key-op" data-key="+">+</button>

        <!-- Row 4: 0, Dot, Exp, Ans, Equals -->
        <button class="key-num" data-key="0">0</button>
        <button class="key-num" data-key=".">.</button>
        <button class="key-sci font-sans text-xs" data-key="×10ˣ">×10ˣ</button>
        <button class="key-sci" data-key="ans" id="btn-ans">Ans</button>
        <button class="key-action active-glow" data-key="equals">=</button>
      </div>
    </div>
  </div>

  <style>
    /* Styling key groups matching Vercel Design Language */
    #toggle-deg, #toggle-rad {
      height: 100% !important;
      min-height: 0 !important;
      border-radius: 9999px;
    }

    button {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 0.75rem;
      font-weight: 500;
      height: 44px;
      min-height: 44px;
      border-radius: 6px;
      transition: all 0.15s ease-in-out;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      user-select: none;
      outline: none;
    }
    @media (min-width: 640px) {
      button {
        font-size: 0.875rem;
      }
    }
    
    .key-num {
      background-color: var(--color-brand-gray-dark);
      border: 1px solid var(--color-brand-border);
      color: var(--color-brand-text);
    }
    .key-num:hover {
      background-color: var(--color-brand-gray-hover);
      border-color: var(--color-brand-border-hover);
    }
    .key-num:active {
      background-color: var(--color-brand-gray-light);
    }

    .key-sci {
      background-color: var(--color-brand-gray-light);
      border: 1px solid var(--color-brand-border);
      color: var(--color-brand-text-muted);
    }
    .key-sci:hover {
      background-color: var(--color-brand-gray-hover);
      color: var(--color-brand-text);
      border-color: var(--color-brand-border-hover);
    }
    .key-sci:active {
      background-color: var(--color-brand-gray-dark);
    }

    .key-op {
      background-color: rgba(0, 112, 243, 0.06);
      border: 1px solid rgba(0, 112, 243, 0.2);
      color: var(--color-brand-blue);
      font-weight: 600;
    }
    .key-op:hover {
      background-color: rgba(0, 112, 243, 0.15);
      color: var(--color-brand-blue-neon);
      border-color: var(--color-brand-blue);
    }
    .key-op:active {
      background-color: rgba(0, 112, 243, 0.25);
    }

    .key-cmd {
      background-color: rgba(234, 67, 53, 0.06);
      border: 1px solid rgba(234, 67, 53, 0.2);
      color: #ea4335;
    }
    .key-cmd:hover {
      background-color: rgba(234, 67, 53, 0.15);
      border-color: #ea4335;
    }
    .key-cmd:active {
      background-color: rgba(234, 67, 53, 0.25);
    }

    .key-action {
      background-color: var(--color-brand-blue);
      border: 1px solid var(--color-brand-blue-hover);
      color: #ffffff;
      font-weight: 600;
      font-size: 0.875rem;
    }
    @media (min-width: 640px) {
      .key-action {
        font-size: 1rem;
      }
    }
    .key-action:hover {
      background-color: var(--color-brand-blue-hover);
      box-shadow: 0 0 10px rgba(0, 112, 243, 0.4);
    }
    .key-action:active {
      background-color: #003e8a;
    }
  </style>

  <script>
    // --- Expression Parser Logic ---
    function tokenize(str: string) {
      // Regex for numbers, DMS tokens (e.g. 12°30'45''), scientific functions, brackets, operators, commas
      const regex = /\d+(\.\d*)?°(\d+(\.\d*)?')?(\d+(\.\d*)'')?|\d+(\.\d*)?(e[+-]?\d+)?|[a-zA-Z_]+|\+|\-|\*|\/|\^|\%|\(|\)|\!|\,/g;
      return str.match(regex) || [];
    }

    function parse(tokens: string[]) {
      const outputQueue: any[] = [];
      const operatorStack: string[] = [];
      
      const operators: Record<string, { precedence: number; associativity: 'Left' | 'Right'; isUnary: boolean }> = {
        '+': { precedence: 2, associativity: 'Left', isUnary: false },
        '-': { precedence: 2, associativity: 'Left', isUnary: false },
        '*': { precedence: 3, associativity: 'Left', isUnary: false },
        '/': { precedence: 3, associativity: 'Left', isUnary: false },
        '%': { precedence: 3, associativity: 'Left', isUnary: false },
        'nCr': { precedence: 3, associativity: 'Left', isUnary: false },
        'nPr': { precedence: 3, associativity: 'Left', isUnary: false },
        '^': { precedence: 4, associativity: 'Right', isUnary: false },
        'u-': { precedence: 5, associativity: 'Right', isUnary: true },
        'u+': { precedence: 5, associativity: 'Right', isUnary: true }
      };

      const functions = new Set([
        'sin', 'cos', 'tan', 'asin', 'acos', 'atan', 
        'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh',
        'log', 'ln', 'logBase', 'sqrt', 'abs', 'fact'
      ]);

      for (let i = 0; i < tokens.length; i++) {
        const token = tokens[i];
        
        // Unary operator detection
        if (token === '-' || token === '+') {
          const prev = tokens[i - 1];
          const isUnary = i === 0 || prev === '(' || prev === ',' || prev === '+' || prev === '-' || prev === '*' || prev === '/' || prev === '^' || prev === '%';
          if (isUnary) {
            const uToken = token === '-' ? 'u-' : 'u+';
            const op = operators[uToken];
            while (operatorStack.length > 0) {
              const top = operatorStack[operatorStack.length - 1];
              if (operators[top] && (operators[top].precedence > op.precedence || (operators[top].precedence === op.precedence && op.associativity === 'Left'))) {
                outputQueue.push(operatorStack.pop());
              } else {
                break;
              }
            }
            operatorStack.push(uToken);
            continue;
          }
        }

        if (token.includes('°')) {
          outputQueue.push({ type: 'number', value: parseDMSToken(token) });
        } else if (!isNaN(parseFloat(token)) && isFinite(token as any)) {
          outputQueue.push({ type: 'number', value: parseFloat(token) });
        } else if (token === 'pi' || token === 'π') {
          outputQueue.push({ type: 'number', value: Math.PI });
        } else if (token === 'e') {
          outputQueue.push({ type: 'number', value: Math.E });
        } else if (functions.has(token)) {
          operatorStack.push(token);
        } else if (operators[token]) {
          const op = operators[token];
          while (operatorStack.length > 0) {
            const top = operatorStack[operatorStack.length - 1];
            if (functions.has(top)) {
              outputQueue.push(operatorStack.pop());
            } else if (operators[top] && (operators[top].precedence > op.precedence || (operators[top].precedence === op.precedence && op.associativity === 'Left'))) {
              outputQueue.push(operatorStack.pop());
            } else {
              break;
            }
          }
          operatorStack.push(token);
        } else if (token === '(') {
          operatorStack.push(token);
        } else if (token === ')') {
          let foundOpen = false;
          while (operatorStack.length > 0) {
            const top = operatorStack.pop();
            if (top === '(') {
              foundOpen = true;
              break;
            } else {
              outputQueue.push(top);
            }
          }
          if (!foundOpen) throw new Error('Mismatched parentheses');
        } else if (token === ',') {
          let foundOpen = false;
          while (operatorStack.length > 0) {
            const top = operatorStack[operatorStack.length - 1];
            if (top === '(') {
              foundOpen = true;
              break;
            } else {
              outputQueue.push(operatorStack.pop());
            }
          }
          if (!foundOpen) throw new Error('Comma misplaced or mismatched parentheses');
        } else if (token === '!') {
          outputQueue.push('!');
        } else {
          throw new Error(`Unknown token: ${token}`);
        }
      }

      while (operatorStack.length > 0) {
        const top = operatorStack.pop();
        if (top === '(' || top === ')') throw new Error('Mismatched parentheses');
        outputQueue.push(top);
      }

      return outputQueue;
    }

    function parseDMSToken(token: string): number {
      const match = token.match(/^(\d+(?:\.\d*)?)°(?:(\d+(?:\.\d*)?)')?(?:(\d+(?:\.\d*)?)'')?$/);
      if (!match) return parseFloat(token);
      
      const deg = parseFloat(match[1] || '0');
      const min = parseFloat(match[2] || '0');
      const sec = parseFloat(match[3] || '0');
      
      return deg + min / 60 + sec / 3600;
    }

    function evaluateRPN(rpn: any[]) {
      const stack: number[] = [];
      
      const factorial = (n: number): number => {
        if (n < 0) throw new Error('Factorial negative');
        if (!Number.isInteger(n)) throw new Error('Factorial non-integer');
        if (n === 0 || n === 1) return 1;
        let result = 1;
        for (let i = 2; i <= n; i++) result *= i;
        return result;
      };

      const nCr = (n: number, r: number): number => {
        if (n < 0 || r < 0 || r > n) return 0;
        if (!Number.isInteger(n) || !Number.isInteger(r)) throw new Error('nCr non-integer');
        if (r > n - r) r = n - r;
        let ans = 1;
        for (let i = 1; i <= r; i++) {
          ans = ans * (n - r + i) / i;
        }
        return Math.round(ans);
      };

      const nPr = (n: number, r: number): number => {
        if (n < 0 || r < 0 || r > n) return 0;
        if (!Number.isInteger(n) || !Number.isInteger(r)) throw new Error('nPr non-integer');
        let ans = 1;
        for (let i = n - r + 1; i <= n; i++) {
          ans *= i;
        }
        return ans;
      };

      const adjustTrigInput = (v: number): number => {
        return angleUnit === 'DEG' ? (v * Math.PI) / 180 : v;
      };
      const adjustTrigOutput = (v: number): number => {
        return angleUnit === 'DEG' ? (v * 180) / Math.PI : v;
      };

      for (let i = 0; i < rpn.length; i++) {
        const token = rpn[i];
        if (typeof token === 'object' && token.type === 'number') {
          stack.push(token.value);
        } else if (token === '!') {
          if (stack.length < 1) throw new Error('Syntax error');
          const val = stack.pop()!;
          stack.push(factorial(val));
        } else if (token === 'u-') {
          if (stack.length < 1) throw new Error('Syntax error');
          const val = stack.pop()!;
          stack.push(-val);
        } else if (token === 'u+') {
          if (stack.length < 1) throw new Error('Syntax error');
        } else if (typeof token === 'string') {
          const functions: Record<string, (v: number) => number> = {
            'sin': (v) => Math.sin(adjustTrigInput(v)), 
            'cos': (v) => Math.cos(adjustTrigInput(v)), 
            'tan': (v) => Math.tan(adjustTrigInput(v)),
            'asin': (v) => adjustTrigOutput(Math.asin(v)), 
            'acos': (v) => adjustTrigOutput(Math.acos(v)), 
            'atan': (v) => adjustTrigOutput(Math.atan(v)),
            'sinh': Math.sinh, 'cosh': Math.cosh, 'tanh': Math.tanh,
            'asinh': Math.asinh, 'acosh': Math.acosh, 'atanh': Math.atanh,
            'log': Math.log10, 'ln': Math.log, 'sqrt': Math.sqrt,
            'abs': Math.abs, 'fact': factorial
          };
          
          if (token === 'logBase') {
            if (stack.length < 2) throw new Error('Syntax error');
            const val = stack.pop()!;
            const base = stack.pop()!;
            if (base <= 0 || base === 1 || val <= 0) throw new Error('Math error');
            stack.push(Math.log(val) / Math.log(base));
          } else if (functions[token]) {
            if (stack.length < 1) throw new Error('Syntax error');
            const val = stack.pop()!;
            stack.push(functions[token](val));
          } else {
            if (stack.length < 2) throw new Error('Syntax error');
            const b = stack.pop()!;
            const a = stack.pop()!;
            
            switch (token) {
              case '+': stack.push(a + b); break;
              case '-': stack.push(a - b); break;
              case '*': stack.push(a * b); break;
              case '/': 
                if (b === 0) throw new Error('Divide by zero');
                stack.push(a / b); 
                break;
              case '%': stack.push(a % b); break;
              case '^': stack.push(Math.pow(a, b)); break;
              case 'nCr': stack.push(nCr(a, b)); break;
              case 'nPr': stack.push(nPr(a, b)); break;
              default: throw new Error(`Unknown operator: ${token}`);
            }
          }
        }
      }
      
      if (stack.length !== 1) throw new Error('Syntax error');
      return stack[0];
    }

    // High precision rounding to solve float arithmetic
    function cleanResult(val: number) {
      if (typeof val !== 'number' || isNaN(val) || !isFinite(val)) return val;
      const res = Number(val.toPrecision(12));
      return res;
    }

    // Convert decimal numbers to rational fractions
    function decimalToFractionSimple(val: number): string {
      if (typeof val !== 'number' || isNaN(val) || !isFinite(val)) return String(val);
      if (Number.isInteger(val)) return String(val);
      const sign = val < 0 ? '-' : '';
      const absVal = Math.abs(val);
      let tolerance = 1.e-9;
      let h1 = 1, h2 = 0, k1 = 0, k2 = 1;
      let b = absVal;
      do {
        let a = Math.floor(b);
        let aux = h1; h1 = a * h1 + h2; h2 = aux;
        aux = k1; k1 = a * k1 + k2; k2 = aux;
        b = 1 / (b - a);
      } while (Math.abs(absVal - h1 / k1) > absVal * tolerance && k1 < 10000);

      if (k1 >= 10000) return String(cleanResult(val));
      return `${sign}${h1}/${k1}`;
    }

    function decimalToFractionMixed(val: number): string {
      if (typeof val !== 'number' || isNaN(val) || !isFinite(val)) return String(val);
      if (Number.isInteger(val)) return String(val);
      const sign = val < 0 ? '-' : '';
      const absVal = Math.abs(val);
      let tolerance = 1.e-9;
      let h1 = 1, h2 = 0, k1 = 0, k2 = 1;
      let b = absVal;
      do {
        let a = Math.floor(b);
        let aux = h1; h1 = a * h1 + h2; h2 = aux;
        aux = k1; k1 = a * k1 + k2; k2 = aux;
        b = 1 / (b - a);
      } while (Math.abs(absVal - h1 / k1) > absVal * tolerance && k1 < 10000);

      if (k1 >= 10000) return String(cleanResult(val));
      if (h1 > k1 && k1 > 1) {
        const whole = Math.floor(h1 / k1);
        const num = h1 % k1;
        if (num > 0) {
          return `${sign}${whole}_${num}/${k1}`;
        }
      }
      return `${sign}${h1}/${k1}`;
    }

    // Convert decimal numbers to DMS format
    function decimalToDMS(val: number): string {
      if (typeof val !== 'number' || isNaN(val) || !isFinite(val)) return String(val);
      const sign = val < 0 ? '-' : '';
      const absVal = Math.abs(val);
      
      const deg = Math.floor(absVal);
      const minVal = (absVal - deg) * 60;
      const min = Math.floor(minVal);
      const secVal = (minVal - min) * 60;
      const sec = Number(secVal.toFixed(2));
      
      return `${sign}${deg}°${min}'${sec}''`;
    }

    // --- Core UI Management ---
    let expression = '';
    let lastAns = '0';
    let isHyperbolic = false;
    let isShift = false;
    let angleUnit = 'RAD';
    let memoryValue = parseFloat(localStorage.getItem('scicalcx_memory') || '0');
    
    let numericResult: number | null = null;
    let sdMode: 'decimal' | 'fraction' | 'mixed' = 'decimal';

    const rawInput = document.getElementById('raw-input') as HTMLInputElement;
    const displayContainer = document.getElementById('display-container')!;
    const displayTokens = document.getElementById('display-tokens')!;
    const displayResult = document.getElementById('display-result')!;
    const bracketValidation = document.getElementById('bracket-validation')!;
    const btnAns = document.getElementById('btn-ans')!;
    const memoryIndicator = document.getElementById('memory-indicator')!;

    const toggleDeg = document.getElementById('toggle-deg')!;
    const toggleRad = document.getElementById('toggle-rad')!;
    const angleSlider = document.getElementById('angle-slider')!;

    const btnShift = document.getElementById('btn-shift')!;
    const btnHyp = document.getElementById('btn-hyp')!;
    const btnSin = document.getElementById('btn-sin')!;
    const btnCos = document.getElementById('btn-cos')!;
    const btnTan = document.getElementById('btn-tan')!;
    const btnDiv = document.getElementById('btn-div')!;
    const btnMult = document.getElementById('btn-mult')!;
    const btnMr = document.getElementById('btn-mr')!;
    const btnMplus = document.getElementById('btn-mplus')!;
    const btnParenClose = document.getElementById('btn-paren-close')!;

    displayContainer.addEventListener('click', () => {
      rawInput.focus();
    });

    function sanitizeInput(currentVal: string, nextChar: string) {
      const operators = ['+', '*', '/', '^', '%'];
      if (currentVal === '' && operators.includes(nextChar)) return '';
      
      const lastChar = currentVal[currentVal.length - 1];
      if (nextChar === '.') {
        const tokens = tokenize(currentVal);
        const lastToken = tokens[tokens.length - 1] || '';
        const isOperator = ['+', '-', '*', '/', '^', '%', '(', ')', '!'].includes(lastToken);
        if (!isOperator && lastToken.includes('.')) return currentVal;
      }
      
      const allOps = ['+', '-', '*', '/', '^', '%'];
      if (allOps.includes(nextChar)) {
        if (allOps.includes(lastChar)) {
          if (nextChar === '-' && ['*', '/', '+', '(', '^', '%'].includes(lastChar)) return currentVal + nextChar;
          if (currentVal.length >= 2) {
            const secondToLast = currentVal[currentVal.length - 2];
            if (allOps.includes(secondToLast)) return currentVal.slice(0, -2) + nextChar;
          }
          return currentVal.slice(0, -1) + nextChar;
        }
      }
      return currentVal + nextChar;
    }

    function generateHighlightHtml(expr: string) {
      if (!expr) return `<span class="text-brand-text-dim italic">Type or press keys to calculate...</span>`;
      
      const tokens = tokenize(expr);
      const openIndices: number[] = [];
      const matchMap: Record<number, boolean> = {};
      
      tokens.forEach((tok, idx) => {
        if (tok === '(') {
          openIndices.push(idx);
        } else if (tok === ')') {
          if (openIndices.length > 0) {
            const openIdx = openIndices.pop()!;
            matchMap[openIdx] = true;
            matchMap[idx] = true;
          } else {
            matchMap[idx] = false;
          }
        }
      });
      openIndices.forEach((idx) => { matchMap[idx] = false; });

      const functions = new Set([
        'sin', 'cos', 'tan', 'asin', 'acos', 'atan', 
        'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh',
        'log', 'ln', 'logBase', 'sqrt', 'abs', 'fact'
      ]);
      const constants = new Set(['pi', 'e', 'π']);
      const operators = new Set(['+', '-', '*', '/', '^', '%', '!', 'nCr', 'nPr', ',']);

      return tokens
        .map((tok, idx) => {
          if (tok.includes('°') || (!isNaN(parseFloat(tok)) && isFinite(tok as any))) {
            return `<span class="token-number">${tok}</span>`;
          } else if (constants.has(tok)) {
            return `<span class="token-constant font-medium">${tok}</span>`;
          } else if (functions.has(tok)) {
            return `<span class="token-function font-medium">${tok}</span>`;
          } else if (operators.has(tok)) {
            return `<span class="token-operator font-semibold">${tok}</span>`;
          } else if (tok === '(' || tok === ')') {
            const matched = matchMap[idx];
            return `<span class="${matched ? 'token-paren-match' : 'token-paren-error'}">${tok}</span>`;
          } else if (tok === '.') {
            return `<span class="token-number">${tok}</span>`;
          }
          return `<span class="token-paren-error">${tok}</span>`;
        })
        .join('');
    }

    function updateBracketStatus() {
      const tokens = tokenize(expression);
      let openCount = 0;
      let closeCount = 0;
      tokens.forEach(tok => {
        if (tok === '(') openCount++;
        if (tok === ')') closeCount++;
      });
      if (openCount > closeCount) {
        bracketValidation.innerHTML = `<span class="text-brand-blue-neon font-medium">Unclosed: ${openCount - closeCount} )</span>`;
      } else if (closeCount > openCount) {
        bracketValidation.innerHTML = `<span class="text-red-500 font-medium">Extra: ${closeCount - openCount} )</span>`;
      } else {
        bracketValidation.innerHTML = expression ? `<span class="text-emerald-400 font-medium">Syntax valid</span>` : '';
      }
    }

    function updateDisplay() {
      displayTokens.innerHTML = generateHighlightHtml(expression);
      updateBracketStatus();
      if (!expression) {
        displayResult.textContent = '0';
        displayResult.classList.remove('text-red-500', 'text-brand-blue-neon');
        displayResult.classList.add('text-brand-text');
        return;
      }
      try {
        const tokens = tokenize(expression);
        const rpn = parse(tokens);
        const rawRes = evaluateRPN(rpn);
        const clean = cleanResult(rawRes);
        displayResult.textContent = isNaN(clean) ? 'Error' : String(clean);
        displayResult.classList.remove('text-red-500');
        displayResult.classList.add('text-brand-text');
      } catch (err: any) {
        displayResult.textContent = '...';
        displayResult.classList.remove('text-red-500');
        displayResult.classList.add('text-brand-text-dim');
      }
    }

    function setAngleUnit(unit: 'DEG' | 'RAD') {
      angleUnit = unit;
      if (unit === 'DEG') {
        angleSlider.style.transform = 'translateX(0px)';
        toggleDeg.classList.remove('text-brand-text-muted');
        toggleDeg.classList.add('text-brand-black');
        toggleRad.classList.remove('text-brand-black');
        toggleRad.classList.add('text-brand-text-muted');
      } else {
        angleSlider.style.transform = 'translateX(44px)';
        toggleRad.classList.remove('text-brand-text-muted');
        toggleRad.classList.add('text-brand-black');
        toggleDeg.classList.remove('text-brand-black');
        toggleDeg.classList.add('text-brand-text-muted');
      }
      updateDisplay();
    }

    function updateShiftUI() {
      if (isShift) {
        btnShift.classList.add('bg-brand-blue/10', 'border-brand-blue', 'text-brand-blue-neon');
        btnShift.classList.remove('bg-brand-gray-light', 'text-brand-text-muted');
        btnDiv.textContent = 'nCr';
        btnDiv.setAttribute('data-key', 'nCr');
        btnMult.textContent = 'nPr';
        btnMult.setAttribute('data-key', 'nPr');
        btnMr.textContent = 'MC';
        btnMr.setAttribute('data-key', 'MC');
        btnMplus.textContent = 'M-';
        btnMplus.setAttribute('data-key', 'M-');
        btnParenClose.textContent = ',';
        btnParenClose.setAttribute('data-key', ',');
      } else {
        btnShift.classList.remove('bg-brand-blue/10', 'border-brand-blue', 'text-brand-blue-neon');
        btnShift.classList.add('bg-brand-gray-light', 'text-brand-text-muted');
        btnDiv.textContent = '/';
        btnDiv.setAttribute('data-key', '/');
        btnMult.textContent = '*';
        btnMult.setAttribute('data-key', '*');
        btnMr.textContent = 'MR';
        btnMr.setAttribute('data-key', 'MR');
        btnMplus.textContent = 'M+';
        btnMplus.setAttribute('data-key', 'M+');
        btnParenClose.textContent = ')';
        btnParenClose.setAttribute('data-key', ')');
      }
      updateTrigLabels();
    }

    function updateTrigLabels() {
      if (isHyperbolic) {
        btnHyp.classList.add('bg-brand-blue/10', 'border-brand-blue', 'text-brand-blue-neon');
        btnHyp.classList.remove('bg-brand-gray-light', 'text-brand-text-muted');
        if (isShift) {
          btnSin.textContent = 'asinh';
          btnSin.setAttribute('data-key', 'asinh');
          btnCos.textContent = 'acosh';
          btnCos.setAttribute('data-key', 'acosh');
          btnTan.textContent = 'atanh';
          btnTan.setAttribute('data-key', 'atanh');
        } else {
          btnSin.textContent = 'sinh';
          btnSin.setAttribute('data-key', 'sinh');
          btnCos.textContent = 'cosh';
          btnCos.setAttribute('data-key', 'cosh');
          btnTan.textContent = 'tanh';
          btnTan.setAttribute('data-key', 'tanh');
        }
      } else {
        btnHyp.classList.remove('bg-brand-blue/10', 'border-brand-blue', 'text-brand-blue-neon');
        btnHyp.classList.add('bg-brand-gray-light', 'text-brand-text-muted');
        if (isShift) {
          btnSin.textContent = 'sin⁻¹';
          btnSin.setAttribute('data-key', 'asin');
          btnCos.textContent = 'cos⁻¹';
          btnCos.setAttribute('data-key', 'acos');
          btnTan.textContent = 'tan⁻¹';
          btnTan.setAttribute('data-key', 'atan');
        } else {
          btnSin.textContent = 'sin';
          btnSin.setAttribute('data-key', 'sin');
          btnCos.textContent = 'cos';
          btnCos.setAttribute('data-key', 'cos');
          btnTan.textContent = 'tan';
          btnTan.setAttribute('data-key', 'tan');
        }
      }
    }

    function updateMemoryIndicator() {
      if (memoryValue !== 0) memoryIndicator.classList.remove('hidden');
      else memoryIndicator.classList.add('hidden');
    }

    function processKey(key: string) {
      if (['equals', 'SD', 'DMS'].indexOf(key) === -1) {
        numericResult = null;
        sdMode = 'decimal';
      }
      if (key === 'clear') {
        expression = '';
      } else if (key === 'shift') {
        isShift = !isShift;
        updateShiftUI();
        return;
      } else if (key === 'CE') {
        if (expression) {
          const tokens = tokenize(expression);
          if (tokens.length > 0) {
            tokens.pop();
            expression = tokens.join('');
          }
        }
      } else if (key === 'backspace') {
        const functions = [
          'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh',
          'sin', 'cos', 'tan', 'logBase', 'log', 'ln', 'sqrt', 'fact', 'asin', 'acos', 'atan'
        ];
        let matchedFunc = false;
        for (const func of functions) {
          if (expression.endsWith(func + '(')) {
            expression = expression.slice(0, -(func.length + 1));
            matchedFunc = true;
            break;
          } else if (expression.endsWith(func)) {
            expression = expression.slice(0, -func.length);
            matchedFunc = true;
            break;
          }
        }
        if (!matchedFunc) {
          if (expression.endsWith('nCr ')) expression = expression.slice(0, -4);
          else if (expression.endsWith('nPr ')) expression = expression.slice(0, -4);
          else if (expression.endsWith("''")) expression = expression.slice(0, -2);
          else if (expression.endsWith(' ')) expression = expression.slice(0, -1);
          else expression = expression.slice(0, -1);
        }
      } else if (key === 'hyp') {
        isHyperbolic = !isHyperbolic;
        updateTrigLabels();
        return;
      } else if (key === 'MC') {
        memoryValue = 0;
        localStorage.setItem('scicalcx_memory', '0');
        updateMemoryIndicator();
        return;
      } else if (key === 'MR') {
        expression = sanitizeInput(expression, String(memoryValue));
      } else if (key === 'M+') {
        try {
          if (!expression) return;
          const tokens = tokenize(expression);
          const rpn = parse(tokens);
          const result = evaluateRPN(rpn);
          if (isNaN(result) || !isFinite(result)) throw new Error('Invalid output');
          memoryValue += result;
          localStorage.setItem('scicalcx_memory', String(memoryValue));
          updateMemoryIndicator();
        } catch (err) {
          displayResult.textContent = 'Syntax Error';
          displayResult.classList.remove('text-brand-text');
          displayResult.classList.add('text-red-500');
        }
        return;
      } else if (key === 'M-') {
        try {
          if (!expression) return;
          const tokens = tokenize(expression);
          const rpn = parse(tokens);
          const result = evaluateRPN(rpn);
          if (isNaN(result) || !isFinite(result)) throw new Error('Invalid output');
          memoryValue -= result;
          localStorage.setItem('scicalcx_memory', String(memoryValue));
          updateMemoryIndicator();
        } catch (err) {
          displayResult.textContent = 'Syntax Error';
          displayResult.classList.remove('text-brand-text');
          displayResult.classList.add('text-red-500');
        }
        return;
      } else if (key === 'SD') {
        if (numericResult !== null) {
          if (sdMode === 'decimal') { sdMode = 'fraction'; displayResult.textContent = decimalToFractionSimple(numericResult); }
          else if (sdMode === 'fraction') { sdMode = 'mixed'; displayResult.textContent = decimalToFractionMixed(numericResult); }
          else { sdMode = 'decimal'; displayResult.textContent = String(cleanResult(numericResult)); }
        }
        return;
      } else if (key === 'DMS') {
        if (numericResult !== null) {
          if (displayResult.textContent?.includes('°')) displayResult.textContent = String(cleanResult(numericResult));
          else displayResult.textContent = decimalToDMS(numericResult);
          return;
        }
        const matchSec = expression.match(/\d+(?:\.\d*)?'\d+(?:\.\d*)?$/);
        const matchMin = expression.match(/\d+(?:\.\d*)?°\d+(?:\.\d*)?$/);
        const matchDeg = expression.match(/\d+(?:\.\d*)?$/);
        if (matchSec) expression += "''";
        else if (matchMin) expression += "'";
        else if (matchDeg) expression += "°";
        else expression = sanitizeInput(expression, "0°");
      } else if (key === 'equals') {
        if (!expression) return;
        try {
          const tokens = tokenize(expression);
          const rpn = parse(tokens);
          const result = evaluateRPN(rpn);
          numericResult = result;
          sdMode = 'decimal';
          const clean = cleanResult(result);
          const finalResult = isNaN(clean) ? 'Error' : String(clean);
          lastAns = finalResult;
          btnAns.textContent = `Ans (${lastAns})`;
          window.dispatchEvent(new CustomEvent('add-history', { detail: { expr: expression, result: finalResult, mode: 'scientific' } }));
          expression = finalResult;
          displayResult.textContent = finalResult;
          displayResult.classList.remove('text-brand-text-dim', 'text-red-500');
          displayResult.classList.add('text-brand-blue-neon');
        } catch (err: any) {
          numericResult = null;
          displayResult.textContent = 'Syntax Error';
          displayResult.classList.remove('text-brand-text');
          displayResult.classList.add('text-red-500');
        }
        return;
      } else if (key === 'ans') {
        expression = sanitizeInput(expression, lastAns);
      } else if (key === 'sqr') {
        expression = sanitizeInput(expression, '^2');
      } else if (key === '×10ˣ') {
        expression = sanitizeInput(expression, '*10^');
      } else {
        let character = key;
        if (key === 'pi') character = 'pi';
        const functions = [
          'sin', 'cos', 'tan', 'log', 'ln', 'sqrt', 'abs', 'fact', 'asin', 'acos', 'atan',
          'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh', 'logBase'
        ];
        if (functions.includes(key)) character = key + '(';
        if (key === 'nCr' || key === 'nPr') character = key + ' ';
        expression = sanitizeInput(expression, character);
      }
      if (isShift && key !== 'shift') { isShift = false; updateShiftUI(); }
      updateDisplay();
    }

    window.addEventListener('keydown', (e) => {
      if (document.activeElement?.tagName === 'INPUT' && document.activeElement !== rawInput) return;
      const key = e.key;
      if (key >= '0' && key <= '9') processKey(key);
      else if (['+', '-', '*', '/', '.', '(', ')', '%', '^', '!'].includes(key)) processKey(key);
      else if (key === 'Enter' || key === '=') { e.preventDefault(); processKey('equals'); }
      else if (key === 'Backspace') { e.preventDefault(); processKey('backspace'); }
      else if (key === 'Delete') { e.preventDefault(); processKey('CE'); }
      else if (key === 'Escape') processKey('clear');
      else if (key === 'c' || key === 'C') processKey('nCr');
      else if (key === 'p' || key === 'P') processKey('nPr');
      else if (key === 'h' || key === 'H') processKey('hyp');
      else if (key === 's' || key === 'S') processKey('shift');
      else if (key === 'd' || key === 'D') processKey('DMS');
      else if (key === 'f' || key === 'F') processKey('SD');
    });

    document.querySelectorAll('button[data-key]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-key')!;
        processKey(key);
        rawInput.focus();
      });
    });

    toggleDeg.addEventListener('click', () => setAngleUnit('DEG'));
    toggleRad.addEventListener('click', () => setAngleUnit('RAD'));

    window.addEventListener('load-expression', (e: any) => {
      if (e.detail.mode === 'scientific') { expression = e.detail.expression; updateDisplay(); }
    });

    updateMemoryIndicator();
    updateDisplay();
  </script>
</Layout>

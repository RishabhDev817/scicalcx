---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  activeTab="scientific"
  title="SciCalcX | Best Online Scientific Calculator & Math Solver"
  description="Use the best free online scientific calculator for advanced web calculations, fractions, matrices, graphing, and programmer base-n conversions. High-performance multi-line engineering calculator and math expression solver."
>
  <div class="w-full max-w-2xl mx-auto space-y-4 sm:space-y-6">
    <!-- Page Header and Eyebrow -->
    <div class="text-center md:text-left space-y-1.5 border-b border-brand-border/60 pb-3 sm:pb-4">
      <div class="text-[9px] sm:text-[10px] font-mono uppercase tracking-widest text-brand-blue-neon">
        System Mode: Core Compute
      </div>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-3">
        <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-brand-text">
          Scientific Calculator<span class="text-brand-blue">.</span>
        </h1>
        <div class="flex flex-wrap justify-center md:justify-end gap-2 text-[9px] sm:text-[10px] font-mono">
          <a href="/about" class="px-2 py-0.5 border border-brand-border rounded hover:border-brand-border-hover hover:text-white transition-all bg-brand-gray-light/40">About Us</a>
          <a href="/contact" class="px-2 py-0.5 border border-brand-border rounded hover:border-brand-border-hover hover:text-white transition-all bg-brand-gray-light/40">Contact Us</a>
          <a href="/terms" class="px-2 py-0.5 border border-brand-border rounded hover:border-brand-border-hover hover:text-white transition-all bg-brand-gray-light/40">Terms</a>
          <a href="/privacy" class="px-2 py-0.5 border border-brand-border rounded hover:border-brand-border-hover hover:text-white transition-all bg-brand-gray-light/40">Privacy</a>
        </div>
      </div>
    </div>

    <!-- Live Engine Status Bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-2 px-3 py-1.5 bg-brand-gray-light/40 border border-brand-border rounded text-[9px] sm:text-[10px] font-mono text-brand-text-muted">
      <div class="flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span>ENGINE STATUS: ACTIVE</span>
        <span id="memory-indicator" class="hidden ml-2 px-1.5 py-0.5 bg-brand-blue/10 border border-brand-blue/30 text-brand-blue-neon rounded text-[8px] font-bold tracking-wider animate-pulse">
          M
        </span>
      </div>
      <div class="flex items-center gap-2 sm:gap-4">
        <span class="hidden sm:inline">PRECISION: FLOAT64 (12-DEC)</span>
        <!-- Sleek DEG/RAD slider toggle capsule -->
        <div class="relative flex items-center bg-brand-black border border-neutral-800 light:border-neutral-300 rounded-full p-0.5 select-none w-24 h-6">
          <div 
            id="angle-slider" 
            class="absolute top-0.5 bottom-0.5 left-0.5 w-[44px] bg-brand-text rounded-full transition-transform duration-200 ease-in-out"
            style="transform: translateX(44px);"
          ></div>
          <button 
            id="toggle-deg" 
            type="button"
            class="relative z-10 flex-1 text-center text-[9px] font-bold font-mono tracking-wider transition-colors duration-200 focus:outline-none cursor-pointer text-brand-text-muted"
          >
            DEG
          </button>
          <button 
            id="toggle-rad" 
            type="button"
            class="relative z-10 flex-1 text-center text-[9px] font-bold font-mono tracking-wider transition-colors duration-200 focus:outline-none cursor-pointer text-brand-black"
          >
            RAD
          </button>
        </div>
      </div>
    </div>

    <!-- Main Calculator Interface -->
    <div class="border border-brand-border bg-brand-gray-dark/40 rounded-xl p-3 sm:p-5 space-y-3 sm:space-y-4 shadow-xl backdrop-blur-sm relative overflow-hidden">
      <!-- Hidden Input for Native Keyboard Interaction -->
      <input 
        type="text" 
        id="raw-input" 
        class="sr-only" 
        autocomplete="off" 
        autocorrect="off" 
        autocapitalize="off" 
        spellcheck="false"
        inputmode="none"
        autofocus
      />

      <!-- Auto-Wrapping Multi-Line Viewport Display -->
      <div 
        id="display-container" 
        class="w-full min-h-[80px] sm:min-h-[96px] bg-brand-black border border-brand-border rounded-lg p-3 sm:p-4 flex flex-col justify-between cursor-text hover:border-brand-border-hover transition-colors focus-within:border-brand-blue focus-within:ring-1 focus-within:ring-brand-blue"
        tabindex="0"
      >
        <!-- Token Matcher Syntax Overlay -->
        <div id="display-tokens" class="w-full text-sm sm:text-base sm:text-lg font-mono break-all whitespace-pre-wrap text-brand-text-muted min-h-[24px] sm:min-h-[28px] leading-relaxed">
          <span class="text-brand-text-dim italic">Type or press keys to calculate...</span>
        </div>

        <!-- Result / Error Real-time Preview Pane -->
        <div class="flex items-end justify-between mt-2 sm:mt-3 pt-2 border-t border-brand-border/30">
          <div id="bracket-validation" class="text-[9px] sm:text-[10px] font-mono text-brand-text-dim">
            <!-- Bracket validation state -->
          </div>
          <div id="display-result" class="text-xl sm:text-2xl sm:text-3xl font-bold font-mono text-brand-text tracking-tight break-all">
            0
          </div>
        </div>
      </div>

      <!-- Middle Scientific Functions Block -->
      <div class="grid grid-cols-3 sm:grid-cols-6 gap-1.5 sm:gap-2">
        <!-- Row 1 -->
        <button class="key-sci font-bold animate-pulse" data-key="shift" id="btn-shift">SHIFT</button>
        <button class="key-sci font-serif text-sm" data-key="/">◼/◼</button>
        <button class="key-sci text-xs" data-key="logBase">log_◼(◻)</button>
        <button class="key-sci text-sm" data-key="sqrt">√◼</button>
        <button class="key-sci text-sm" data-key="sqr">x²</button>
        <button class="key-sci text-sm" data-key="^">x^◼</button>

        <!-- Row 2 -->
        <button class="key-sci text-sm" data-key="log">log</button>
        <button class="key-sci text-sm" data-key="ln">ln</button>
        <button class="key-sci text-sm" data-key="hyp" id="btn-hyp">hyp</button>
        <button class="key-sci text-sm" data-key="sin" id="btn-sin">sin</button>
        <button class="key-sci" data-key="cos" id="btn-cos">cos</button>
        <button class="key-sci" data-key="tan" id="btn-tan">tan</button>

        <!-- Row 3 -->
        <button class="key-sci text-sm" data-key="(">(</button>
        <button class="key-sci text-sm" data-key=")" id="btn-paren-close">)</button>
        <button class="key-sci text-xs" data-key="DMS">° ' ''</button>
        <button class="key-sci text-xs" data-key="SD">S⇔D</button>
        <button class="key-sci" data-key="pi">π</button>
        <button class="key-sci" data-key="e">e</button>
      </div>

      <!-- Divider between zones -->
      <div class="border-t border-brand-border/30 my-2 sm:my-3"></div>

      <!-- Absolute Bottom Number Block -->
      <div class="grid grid-cols-5 gap-1.5 sm:gap-2">
        <!-- Row 0: Clears -->
        <div class="col-span-3"></div>
        <button class="key-cmd font-bold" data-key="backspace">DEL</button>
        <button class="key-cmd font-bold" data-key="clear">AC</button>

        <!-- Row 1: 7-9 & Sub/Div -->
        <button class="key-num" data-key="7">7</button>
        <button class="key-num" data-key="8">8</button>
        <button class="key-num" data-key="9">9</button>
        <button class="key-op" data-key="-">-</button>
        <button class="key-op" data-key="/" id="btn-div">/</button>

        <!-- Row 2: 4-6 & Memory/Mult -->
        <button class="key-num" data-key="4">4</button>
        <button class="key-num" data-key="5">5</button>
        <button class="key-num" data-key="6">6</button>
        <button class="key-sci text-sm" data-key="MR" id="btn-mr">MR</button>
        <button class="key-op" data-key="*" id="btn-mult">*</button>

        <!-- Row 3: 1-3 & Memory/Add -->
        <button class="key-num" data-key="1">1</button>
        <button class="key-num" data-key="2">2</button>
        <button class="key-num" data-key="3">3</button>
        <button class="key-sci text-sm" data-key="M+" id="btn-mplus">M+</button>
        <button class="key-op" data-key="+">+</button>

        <!-- Row 4: 0, Dot, Exp, Ans, Equals -->
        <button class="key-num" data-key="0">0</button>
        <button class="key-num" data-key=".">.</button>
        <button class="key-sci font-sans text-xs" data-key="×10ˣ">×10ˣ</button>
        <button class="key-sci" data-key="ans" id="btn-ans">Ans</button>
        <button class="key-action active-glow" data-key="equals">=</button>
      </div>
    </div>

    <!-- SEO Informational Section -->
    <section class="border-t border-brand-border/40 pt-8 mt-12 text-brand-text-muted font-sans text-xs sm:text-sm leading-relaxed space-y-6">
      <h2 class="text-lg font-bold text-brand-text tracking-tight uppercase font-mono text-brand-blue-neon">
        Ultimate Guide to Our Online Scientific Calculator
      </h2>
      
      <p>
        Welcome to SciCalcX, the ultimate <strong>free online scientific calculator</strong> designed to meet the rigorous demands of students, engineers, and programmers. When looking for the <strong>best online scientific calculator</strong>, professionals need more than just simple arithmetic. They require an <strong>advanced web calculator</strong> that offers speed, high accuracy, and multi-functional capability. SciCalcX provides all these features in a seamless, premium interface that feels both powerful and elegant.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <h3 class="font-bold text-brand-text font-mono uppercase text-xs tracking-wider">
            Multi-Line Engineering Computations
          </h3>
          <p>
            Traditional computational systems often restrict your view to a single line, leading to input errors and forcing you to restart calculations. SciCalcX addresses this limitation directly as a <strong>multi-line engineering calculator</strong>. The auto-wrapping display lets you view complete equations alongside their real-time evaluation. Coupled with our built-in <strong>math expression solver</strong>, you can type nested operations, verify parentheses matching with live visual feedback, and perform high-precision calculations using float64 math engine.
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="font-bold text-brand-text font-mono uppercase text-xs tracking-wider">
            Fractions and DMS Support
          </h3>
          <p>
            Whether you are working in engineering design or carpentry, converting decimal values to fractions or degrees is essential. SciCalcX includes a <strong>free fraction calculator online</strong> capability that converts decimal answers into simple or mixed fractions at the click of a button. In addition, you can input degrees, minutes, and seconds (DMS) directly to compute geographic coordinates or angular values with precision.
          </p>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="font-bold text-brand-text font-mono uppercase text-xs tracking-wider">
          Integrated Advanced Workspaces
        </h3>
        <p>
          SciCalcX is not just a scientific tool; it is a unified math platform. Navigate to our specialized layouts to access more advanced tools. Need to compute vectors or solve complex systems of linear equations? Use our <strong>scientific matrix calculator</strong> to define multiple grids, adjust matrix dimensions on the fly, and perform additions, subtractions, and multiplications, as well as calculate determinants, transposes, and matrix inverses.
        </p>
        <p>
          For algebra and calculus tasks, our suite features definite and indefinite integration utilities, alongside polynomial root solvers for quadratic and cubic equations. If you want to visualize functions, our <strong>graphing derivative calculator online</strong> workspace allows you to plot curves in real-time, trace coordinates dynamically, and analyze key curve attributes like y-intercepts, x-intercepts, and critical extrema values.
        </p>
      </div>

      <div class="space-y-4">
        <h3 class="font-bold text-brand-text font-mono uppercase text-xs tracking-wider">
          Bitwise Logic for Software Engineering
        </h3>
        <p>
          For digital design and low-level development, we have included a <strong>programmer base-n calculator</strong>. Software engineers can switch instantly between hexadecimal (HEX), decimal (DEC), octal (OCT), and binary (BIN) representations. Toggling individual bits on our interactive 32-bit visual bitboard updates values in real-time, making it simple to execute bitwise actions such as NOT, logical shift left (LSH), and logical shift right (RSH) on the fly.
        </p>
      </div>

      <p class="border-t border-brand-border/20 pt-4 text-[10px] text-brand-text-dim">
        SciCalcX stands out as the premium <strong>online scientific calculator</strong> of choice by combining robust mathematical engines with advanced web technology. Discover precision and speed for all your academic, engineering, and coding needs.
      </p>
    </section>

    <!-- FAQ Accordion Section -->
    <section class="border-t border-brand-border/40 pt-8 mt-12 text-brand-text-muted font-sans text-xs sm:text-sm leading-relaxed space-y-6">
      <h2 class="text-lg font-bold text-brand-text tracking-tight uppercase font-mono text-brand-blue-neon">
        Frequently Asked Questions (FAQ)
      </h2>
      
      <div class="space-y-3">
        <!-- 1 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>What is the best scientific calculator online?</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            SciCalcX is considered one of the best scientific calculators online, providing an advanced multi-line computation interface, custom algebra/calculus engines, matrix suites, and programmer base-n tools completely for free.
          </div>
        </details>

        <!-- 2 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>How to use scientific calculator online?</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            Simply type mathematical expressions directly using your physical keyboard, or use your cursor/touch screen to click on the keys of the visual interactive keypad. Results and errors are shown in real-time.
          </div>
        </details>

        <!-- 3 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>What is the best online scientific calculator?</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            The best online scientific calculator is one that provides a high-precision multi-line computation view, real-time feedback, matrix workspaces, fraction output modes, and low-level programmer bases. SciCalcX offers all these tools in a single, high-fidelity responsive package.
          </div>
        </details>

        <!-- 4 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>How to use online scientific calculator?</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            To use SciCalcX, type your equation (like `sin(pi/2) + log(10)`) and tap equals (`=`) or press Enter. You can save, recall, and view previous calculations in the sidebar History panel.
          </div>
        </details>

        <!-- 5 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Where can I find a scientific calculator online?</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            You can access a robust, advanced scientific calculator directly on your web browser at SciCalcX.com. It requires no installations, downloads, or registrations, and works beautifully on smartphones and tablets.
          </div>
        </details>

        <!-- 6 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Math solver</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            SciCalcX includes an advanced math solver engine capable of solving trigonometric values, complex parenthesized arithmetic, algebraic operations, calculus integration limits, and polynomial quadratic/cubic equations.
          </div>
        </details>

        <!-- 7 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Scientific calculator Casio online with shift solve</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            SciCalcX features a shift-key modifier mechanism inspired by high-end Casio calculators, allowing you to access alternative math operators printed above the keys—such as permutations, combinations, and inverse trigs.
          </div>
        </details>

        <!-- 8 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Scientific calculator online equation mode</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            Equation mode is available on our Calculus page. Enter the coefficients for quadratic (ax² + bx + c = 0) or cubic (ax³ + bx² + cx + d = 0) equations to instantly solve and show all real and complex roots.
          </div>
        </details>

        <!-- 9 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Calculator graph online</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            Plot functions dynamically on a coordinate grid by visiting our Graphing page. You can input multiple functions to display curve overlays, calculate intercepts, and evaluate slopes at custom points.
          </div>
        </details>

        <!-- 10 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Math calculator graph online</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            Our graphing simulator offers real-time canvas plotting. Input formulas like `x^2 - 4` or trig functions like `2*sin(x)` to instantly draw math graphs online and view their properties.
          </div>
        </details>

        <!-- 11 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Exponential calculator graph online</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            Plot exponential growth and decay curves using the natural base exponential function `exp(x)` or generic powers like `2^x`. You can trace coordinate values by hovering your cursor over the plot.
          </div>
        </details>

        <!-- 12 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>Math graph online</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            SciCalcX provides responsive math graphing online. Load preset curves like damped oscillations or parabolas to analyze characteristics like Y-intercepts, roots, and peak/valley extrema points.
          </div>
        </details>

        <!-- 13 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>XY graph maker</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            Our XY graph maker tracks coordinates in real-time. Hovering over any section of the plotted curve displays the exact math cursor coordinates, function output, and derivative slope.
          </div>
        </details>

        <!-- 14 -->
        <details class="group border border-brand-border rounded-lg bg-brand-gray-light/20 light:bg-neutral-100 hover:border-brand-border-hover transition-colors overflow-hidden">
          <summary class="flex justify-between items-center p-3 font-semibold text-brand-text cursor-pointer list-none select-none font-mono text-[11px] sm:text-xs tracking-tight">
            <span>How do I switch between Degrees (DEG) and Radians (RAD)?</span>
            <span class="text-brand-blue-neon transition-transform group-open:rotate-180">▼</span>
          </summary>
          <div class="px-3 pb-3 pt-1 border-t border-brand-border/20 text-xs text-brand-text-muted leading-relaxed font-sans">
            Switch between DEG and RAD using the slider toggle in the live status bar at the top of the Scientific calculator layout. The selected mode will apply immediately to all trigonometry functions.
          </div>
        </details>


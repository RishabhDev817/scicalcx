---
import Layout from '../layouts/Layout.astro';
---

<Layout activeTab="statistics">
  <div class="w-full max-w-3xl mx-auto space-y-6">
    <!-- Page Header -->
    <div class="text-center md:text-left space-y-1.5 border-b border-brand-border/60 pb-4">
      <div class="text-[10px] font-mono uppercase tracking-widest text-brand-blue-neon">
        System Mode: Statistical Analysis
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-brand-text">
        Statistical Calculations<span class="text-brand-blue">.</span>
      </h1>
      <p class="text-xs text-brand-text-muted">
        Input raw datasets to instantly compile summaries, variance analysis, sample deviations, and distributions.
      </p>
    </div>

    <!-- Live Status -->
    <div class="flex items-center justify-between px-3 py-1.5 bg-brand-gray-light/40 border border-brand-border rounded text-[10px] font-mono text-brand-text-muted">
      <div>DATA SET COUNT: <span id="data-count">0</span> items</div>
      <div>STATUS: <span id="data-status" class="text-brand-blue-neon">Awaiting data...</span></div>
    </div>

    <!-- Statistics Workspace -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Input Card (Col 1) -->
      <div class="md:col-span-1 border border-brand-border bg-brand-gray-dark/40 rounded-xl p-5 space-y-4 flex flex-col justify-between">
        <div class="space-y-2">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-white font-mono flex items-center gap-1.5">
            Dataset Input
          </h2>
          <p class="text-[11px] text-brand-text-muted">
            Enter numbers separated by commas, spaces, or newlines.
          </p>
        </div>

        <textarea
          id="data-input"
          class="flex-1 min-h-[180px] bg-brand-black hover:border-brand-border-hover focus:border-brand-blue border border-brand-border rounded-lg p-3 text-sm font-mono text-white focus:outline-none focus:ring-1 focus:ring-brand-blue/30 resize-none mt-2 placeholder:text-brand-text-dim"
          placeholder="e.g. 12, 19, 3, 5, 2, 3, 9, 14, 16"
        ></textarea>

        <div class="grid grid-cols-2 gap-2 mt-4">
          <button id="btn-clear-data" class="text-xs py-2 border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-text-muted hover:text-white rounded transition-all cursor-pointer">Clear</button>
          <button id="btn-sample-data" class="text-xs py-2 border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-blue-neon hover:text-white rounded transition-all cursor-pointer">Use Sample</button>
        </div>
      </div>

      <!-- Outputs Grid (Col 2 & 3) -->
      <div class="md:col-span-2 space-y-4">
        <!-- Main Stats Summary -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <!-- Stat Card -->
          <div class="border border-brand-border bg-brand-gray-dark/20 rounded-lg p-3.5 space-y-1.5">
            <div class="text-[10px] font-mono text-brand-text-dim light:text-neutral-600 uppercase">Mean (Average)</div>
            <div id="stat-mean" class="text-xl font-bold font-mono text-brand-text">0</div>
          </div>
          <!-- Stat Card -->
          <div class="border border-brand-border bg-brand-gray-dark/20 rounded-lg p-3.5 space-y-1.5">
            <div class="text-[10px] font-mono text-brand-text-dim light:text-neutral-600 uppercase">Median</div>
            <div id="stat-median" class="text-xl font-bold font-mono text-brand-text">0</div>
          </div>
          <!-- Stat Card -->
          <div class="border border-brand-border bg-brand-gray-dark/20 rounded-lg p-3.5 space-y-1.5">
            <div class="text-[10px] font-mono text-brand-text-dim light:text-neutral-600 uppercase">Mode</div>
            <div id="stat-mode" class="text-xl font-bold font-mono text-brand-text">0</div>
          </div>
          <!-- Stat Card -->
          <div class="border border-brand-border bg-brand-gray-dark/20 rounded-lg p-3.5 space-y-1.5">
            <div class="text-[10px] font-mono text-brand-text-dim light:text-neutral-600 uppercase">Min Value</div>
            <div id="stat-min" class="text-xl font-bold font-mono text-brand-text">0</div>
          </div>
          <!-- Stat Card -->
          <div class="border border-brand-border bg-brand-gray-dark/20 rounded-lg p-3.5 space-y-1.5">
            <div class="text-[10px] font-mono text-brand-text-dim light:text-neutral-600 uppercase">Max Value</div>
            <div id="stat-max" class="text-xl font-bold font-mono text-brand-text">0</div>
          </div>
          <!-- Stat Card -->
          <div class="border border-brand-border bg-brand-gray-dark/20 rounded-lg p-3.5 space-y-1.5">
            <div class="text-[10px] font-mono text-brand-text-dim light:text-neutral-600 uppercase">Range</div>
            <div id="stat-range" class="text-xl font-bold font-mono text-brand-text">0</div>
          </div>
        </div>

        <!-- Advanced Variance Summaries -->
        <div class="border border-brand-border bg-brand-gray-dark/30 rounded-xl p-5 space-y-4">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-brand-text-muted font-mono flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-blue-neon"></span> Variance & Dispersion Analysis
          </h3>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
            <!-- Row 1 -->
            <div class="flex items-center justify-between border-b border-brand-border pb-2">
              <span class="text-xs text-brand-text-muted light:text-neutral-500 font-mono">Sample Variance (s&sup2;)</span>
              <span id="stat-variance-sample" class="text-sm font-semibold font-mono text-brand-text">0</span>
            </div>
            <div class="flex items-center justify-between border-b border-brand-border pb-2">
              <span class="text-xs text-brand-text-muted light:text-neutral-500 font-mono">Population Variance (&sigma;&sup2;)</span>
              <span id="stat-variance-pop" class="text-sm font-semibold font-mono text-brand-text">0</span>
            </div>
            <!-- Row 2 -->
            <div class="flex items-center justify-between border-b border-brand-border pb-2">
              <span class="text-xs text-brand-text-muted light:text-neutral-500 font-mono">Sample Std Dev (s)</span>
              <span id="stat-stddev-sample" class="text-sm font-semibold font-mono text-brand-text">0</span>
            </div>
            <div class="flex items-center justify-between border-b border-brand-border pb-2">
              <span class="text-xs text-brand-text-muted light:text-neutral-500 font-mono">Population Std Dev (&sigma;)</span>
              <span id="stat-stddev-pop" class="text-sm font-semibold font-mono text-brand-text">0</span>
            </div>
          </div>

          <div class="pt-3 flex justify-between items-center text-[10px] font-mono text-brand-text-dim">
            <span>SUM VALUE: <span id="stat-sum">0</span></span>
            <button id="btn-save-stats" class="text-brand-blue hover:text-white uppercase transition-colors focus:outline-none">
              [ Save analysis to history ]
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const dataInput = document.getElementById('data-input') as HTMLTextAreaElement;
    const dataCount = document.getElementById('data-count')!;
    const dataStatus = document.getElementById('data-status')!;
    
    // Summary DOM Elements
    const statMean = document.getElementById('stat-mean')!;
    const statMedian = document.getElementById('stat-median')!;
    const statMode = document.getElementById('stat-mode')!;
    const statMin = document.getElementById('stat-min')!;
    const statMax = document.getElementById('stat-max')!;
    const statRange = document.getElementById('stat-range')!;
    const statSum = document.getElementById('stat-sum')!;
    const statVarSample = document.getElementById('stat-variance-sample')!;
    const statVarPop = document.getElementById('stat-variance-pop')!;
    const statDevSample = document.getElementById('stat-stddev-sample')!;
    const statDevPop = document.getElementById('stat-stddev-pop')!;
    
    const btnClear = document.getElementById('btn-clear-data')!;
    const btnSample = document.getElementById('btn-sample-data')!;
    const btnSave = document.getElementById('btn-save-stats')!;

    // Helper: Round value
    function round(val: number) {
      if (isNaN(val) || !isFinite(val)) return 0;
      return Number(val.toPrecision(10));
    }

    function parseData(text: string): number[] {
      // Splits by commas, whitespace, or newlines
      const raw = text.split(/[\s,\n]+/);
      const numbers: number[] = [];
      raw.forEach(token => {
        const num = parseFloat(token);
        if (!isNaN(num) && isFinite(num)) {
          numbers.push(num);
        }
      });
      return numbers;
    }

    function calculateStats() {
      const data = parseData(dataInput.value);
      
      dataCount.textContent = String(data.length);

      if (data.length === 0) {
        dataStatus.textContent = 'Awaiting data...';
        dataStatus.className = 'text-brand-text-dim';
        resetStats();
        return;
      }

      dataStatus.textContent = 'Operational';
      dataStatus.className = 'text-green-500 font-semibold';

      // Sort data for median/mode
      const sorted = [...data].sort((a, b) => a - b);
      
      // Basic metrics
      const sum = data.reduce((acc, val) => acc + val, 0);
      const min = sorted[0];
      const max = sorted[sorted.length - 1];
      const range = max - min;
      const mean = sum / data.length;

      // Median calculation
      let median = 0;
      const mid = Math.floor(sorted.length / 2);
      if (sorted.length % 2 === 0) {
        median = (sorted[mid - 1] + sorted[mid]) / 2;
      } else {
        median = sorted[mid];
      }

      // Mode calculation
      const freq: Record<number, number> = {};
      let maxFreq = 0;
      let modes: number[] = [];
      data.forEach(val => {
        freq[val] = (freq[val] || 0) + 1;
        if (freq[val] > maxFreq) {
          maxFreq = freq[val];
        }
      });
      if (maxFreq > 1) {
        Object.keys(freq).forEach(key => {
          if (freq[Number(key)] === maxFreq) {
            modes.push(Number(key));
          }
        });
      }
      const modeStr = modes.length > 0 ? modes.slice(0, 3).join(', ') + (modes.length > 3 ? '...' : '') : 'N/A';

      // Variance & StdDev
      const squaredDiffSum = data.reduce((acc, val) => acc + Math.pow(val - mean, 2), 0);
      
      // Sample (n - 1)
      const varSample = data.length > 1 ? squaredDiffSum / (data.length - 1) : 0;
      const devSample = Math.sqrt(varSample);

      // Population (n)
      const varPop = squaredDiffSum / data.length;
      const devPop = Math.sqrt(varPop);

      // Populate DOM
      statMean.textContent = String(round(mean));
      statMedian.textContent = String(round(median));
      statMode.textContent = modeStr;
      statMin.textContent = String(min);
      statMax.textContent = String(max);
      statRange.textContent = String(range);
      statSum.textContent = String(sum);
      statVarSample.textContent = String(round(varSample));
      statVarPop.textContent = String(round(varPop));
      statDevSample.textContent = String(round(devSample));
      statDevPop.textContent = String(round(devPop));
    }

    function resetStats() {
      statMean.textContent = '0';
      statMedian.textContent = '0';
      statMode.textContent = '0';
      statMin.textContent = '0';
      statMax.textContent = '0';
      statRange.textContent = '0';
      statSum.textContent = '0';
      statVarSample.textContent = '0';
      statVarPop.textContent = '0';
      statDevSample.textContent = '0';
      statDevPop.textContent = '0';
    }

    // Hook listeners
    dataInput.addEventListener('input', calculateStats);

    btnClear.addEventListener('click', () => {
      dataInput.value = '';
      calculateStats();
    });

    btnSample.addEventListener('click', () => {
      dataInput.value = '2.4, 5.1, 4.3, 10.2, 8.6, 5.1, 3.8, 12.0, 6.7';
      calculateStats();
    });

    // Save statistics analysis to Sidebar History
    btnSave.addEventListener('click', () => {
      const count = dataCount.textContent;
      const mean = statMean.textContent;
      const stdDev = statDevSample.textContent;
      if (count === '0') return;

      const expr = `Dataset Analysis (${count} items)`;
      const result = `μ=${mean}, s=${stdDev}`;
      
      window.dispatchEvent(
        new CustomEvent('add-history', {
          detail: { expr, result, mode: 'statistics' }
        })
      );
    });

    // Handle incoming history item triggers
    window.addEventListener('load-expression', (e: any) => {
      if (e.detail.mode === 'statistics') {
        // Just reload custom loaded prompt
        dataInput.focus();
      }
    });

    // Initial run
    calculateStats();
  </script>
</Layout>

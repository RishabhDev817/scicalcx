---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | SciCalcX" description="The page you are looking for does not exist on SciCalcX online scientific computational suite.">
  <div class="w-full max-w-md mx-auto py-16 text-center space-y-6 sm:space-y-8 font-sans">
    <!-- Eyebrow status code -->
    <div class="inline-flex px-3 py-1 border border-brand-border bg-brand-gray-light/60 text-brand-blue-neon rounded-full font-mono text-xs font-bold tracking-wider animate-pulse">
      STATUS CODE: 404
    </div>

    <!-- Main Message -->
    <div class="space-y-3">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-brand-text font-mono">
        PAGE NOT FOUND<span class="text-brand-blue">.</span>
      </h1>
      <p class="text-xs sm:text-sm text-brand-text-dim max-w-sm mx-auto leading-relaxed">
        The mathematical coordinate or route you requested does not exist in our computational system. Let's redirect you back to base.
      </p>
    </div>

    <!-- Visual Divider -->
    <div class="border-t border-brand-border/40 w-16 mx-auto"></div>

    <!-- CTA Button -->
    <div>
      <a 
        href="/"
        class="inline-flex h-11 px-6 rounded-md bg-brand-blue border border-brand-blue-hover text-white font-medium hover:bg-brand-blue-hover hover:shadow-[0_0_15px_rgba(0,112,243,0.4)] active:bg-brand-blue/80 transition-all cursor-pointer items-center justify-center text-xs tracking-wider uppercase font-mono"
      >
        Return to Home Page
      </a>
    </div>
  </div>
</Layout>

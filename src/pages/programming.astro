---
import Layout from '../layouts/Layout.astro';
---

<Layout activeTab="programming">
  <div class="w-full max-w-2xl mx-auto space-y-6">
    <!-- Page Header -->
    <div class="text-center md:text-left space-y-1.5 border-b border-brand-border/60 pb-4">
      <div class="text-[10px] font-mono uppercase tracking-widest text-brand-blue-neon">
        System Mode: Base-N Programmer
      </div>
      <h1 class="text-3xl font-bold tracking-tight text-brand-text">
        Base-N Programmer View<span class="text-brand-blue">.</span>
      </h1>
      <p class="text-xs text-brand-text-muted">
        Switch between HEX, DEC, OCT, and BIN representations, adjust active bit widths, and execute bitwise operations.
      </p>
    </div>

    <!-- Mode Selector & Value Inputs -->
    <div class="border border-brand-border bg-brand-gray-dark/40 rounded-xl p-5 space-y-3">
      <!-- HEX -->
      <div 
        id="row-hex" 
        class="base-row flex items-center justify-between border border-brand-border rounded-lg p-3 bg-brand-black cursor-pointer hover:border-brand-border-hover transition-colors"
        data-base="16"
      >
        <span class="text-xs font-mono font-semibold text-brand-text-muted light:text-neutral-500 uppercase w-12">HEX</span>
        <input id="display-hex" class="text-lg font-mono font-semibold text-brand-text bg-transparent border-none text-right flex-1 select-all focus:outline-none w-full cursor-default" value="0" readonly />
        <span class="base-indicator text-[9px] font-mono text-brand-blue-neon opacity-0 ml-3">● ACTIVE</span>
      </div>

      <!-- DEC -->
      <div 
        id="row-dec" 
        class="base-row flex items-center justify-between border border-brand-blue rounded-lg p-3 bg-brand-black cursor-pointer transition-colors"
        data-base="10"
      >
        <span class="text-xs font-mono font-semibold text-brand-text-muted light:text-neutral-500 uppercase w-12">DEC</span>
        <input id="display-dec" class="text-lg font-mono font-semibold text-brand-text bg-transparent border-none text-right flex-1 select-all focus:outline-none w-full cursor-text" value="0" />
        <span class="base-indicator text-[9px] font-mono text-brand-blue-neon ml-3">● ACTIVE</span>
      </div>

      <!-- OCT -->
      <div 
        id="row-oct" 
        class="base-row flex items-center justify-between border border-brand-border rounded-lg p-3 bg-brand-black cursor-pointer hover:border-brand-border-hover transition-colors"
        data-base="8"
      >
        <span class="text-xs font-mono font-semibold text-brand-text-muted light:text-neutral-500 uppercase w-12">OCT</span>
        <input id="display-oct" class="text-lg font-mono font-semibold text-brand-text bg-transparent border-none text-right flex-1 select-all focus:outline-none w-full cursor-default" value="0" readonly />
        <span class="base-indicator text-[9px] font-mono text-brand-blue-neon opacity-0 ml-3">● ACTIVE</span>
      </div>

      <!-- BIN -->
      <div 
        id="row-bin" 
        class="base-row flex items-center justify-between border border-brand-border rounded-lg p-3 bg-brand-black cursor-pointer hover:border-brand-border-hover transition-colors"
        data-base="2"
      >
        <span class="text-xs font-mono font-semibold text-brand-text-muted light:text-neutral-500 uppercase w-12">BIN</span>
        <input id="display-bin" class="text-sm sm:text-base font-mono font-semibold text-brand-text bg-transparent border-none text-right flex-1 select-all focus:outline-none w-full cursor-default" value="0" readonly />
        <span class="base-indicator text-[9px] font-mono text-brand-blue-neon opacity-0 ml-3">● ACTIVE</span>
      </div>
    </div>

    <!-- Clickable Interactive 32-Bit Visual Bitboard -->
    <div class="border border-brand-border bg-brand-gray-dark/30 rounded-xl p-5 space-y-3">
      <div class="flex items-center justify-between">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-brand-text-muted font-mono flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-blue"></span> 32-Bit Visual Bitboard
        </h3>
        <span class="text-[9px] font-mono text-brand-text-dim uppercase">Click bits to toggle state</span>
      </div>

      <!-- 32-Bit Toggle Board -->
      <div class="grid grid-cols-8 gap-2 py-2" id="bit-grid">
        <!-- 32 individual boxes from MSB to LSB -->
      </div>
    </div>

    <!-- Bitwise Operator Panel -->
    <div class="border border-brand-border bg-brand-gray-dark/20 rounded-xl p-4 flex flex-wrap gap-2 justify-center items-center">
      <span class="text-xs font-mono text-brand-text-muted px-2">Bitwise Actions:</span>
      <button class="btn-bit-action px-3 py-1.5 text-xs border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-blue-neon rounded font-mono" data-action="not">NOT (~)</button>
      <button class="btn-bit-action px-3 py-1.5 text-xs border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-blue-neon rounded font-mono" data-action="lsh">LSH (&lt;&lt;)</button>
      <button class="btn-bit-action px-3 py-1.5 text-xs border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-blue-neon rounded font-mono" data-action="rsh">RSH (&gt;&gt;)</button>
      <button class="btn-bit-action px-3 py-1.5 text-xs border border-brand-border bg-brand-black hover:bg-brand-gray-hover text-brand-blue-neon rounded font-mono" data-action="clear">AC</button>
    </div>

    <!-- Programmer Keyboard Pad -->
    <div class="border border-brand-border bg-brand-gray-dark/40 rounded-xl p-4 sm:p-6 space-y-4">
      <div class="grid grid-cols-4 gap-2">
        <!-- Hex letter keys A-F -->
        <button class="btn-prog key-hex" data-key="A">A</button>
        <button class="btn-prog key-hex" data-key="B">B</button>
        <button class="btn-prog key-hex" data-key="C">C</button>
        <button class="btn-prog" data-key="DEL" style="color: #ea4335; border-color: #4a1515; background: #1a0808">DEL</button>

        <button class="btn-prog key-hex" data-key="D">D</button>
        <button class="btn-prog key-hex" data-key="E">E</button>
        <button class="btn-prog key-hex" data-key="F">F</button>
        <button class="btn-prog" data-key="AC" style="color: #ea4335; border-color: #4a1515; background: #1a0808">AC</button>

        <!-- Numbers 7-9 -->
        <button class="btn-prog key-dec" data-key="7">7</button>
        <button class="btn-prog key-dec" data-key="8">8</button>
        <button class="btn-prog key-dec" data-key="9">9</button>
        <button class="btn-prog" id="btn-save-prog" style="color: #0070f3; border-color: #102a45; background: #060e1a">SAVE</button>

        <!-- Numbers 4-6 -->
        <button class="btn-prog key-dec" data-key="4">4</button>
        <button class="btn-prog key-dec" data-key="5">5</button>
        <button class="btn-prog key-dec" data-key="6">6</button>
        <button class="btn-prog key-oct" data-key="0">0</button>

        <!-- Numbers 1-3 -->
        <button class="btn-prog key-bin" data-key="1">1</button>
        <button class="btn-prog key-oct" data-key="2">2</button>
        <button class="btn-prog key-oct" data-key="3">3</button>
        <button class="btn-prog col-span-1" data-key="toggle-sign" style="font-size: 10px; color: #888">+/-</button>
      </div>
    </div>
  </div>

  <style>
    button {
      outline: none;
    }
    .btn-prog, .btn-bit-action {
      height: 40px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
      border: 1px solid #1e1e1e;
      border-radius: 6px;
      background: #0c0c0c;
      color: #ffffff;
      font-weight: 500;
      transition: all 0.15s ease-in-out;
      cursor: pointer;
    }
    .btn-prog:hover:not(:disabled), .btn-bit-action:hover:not(:disabled) {
      background-color: #171717;
      border-color: #2e2e2e;
    }
    .btn-prog:disabled, .btn-bit-action:disabled {
      opacity: 0.15;
      cursor: not-allowed;
      border-color: #121212 !important;
      background-color: #050505 !important;
      color: #555555 !important;
    }
  </style>

  <script>
    let activeBase = 10;
    let currentValue = 0; // Stored value as a standard signed 32-bit integer

    const displayHex = document.getElementById('display-hex') as HTMLInputElement;
    const displayDec = document.getElementById('display-dec') as HTMLInputElement;
    const displayOct = document.getElementById('display-oct') as HTMLInputElement;
    const displayBin = document.getElementById('display-bin') as HTMLInputElement;
    const bitGrid = document.getElementById('bit-grid')!;

    // Initial grid population (32 bits)
    function buildBitboard() {
      let html = '';
      for (let i = 31; i >= 0; i--) {
        const bit = (currentValue >>> i) & 1;
        html += `
          <div class="flex flex-col items-center space-y-1">
            <button 
              class="bit-box w-6 h-6 border rounded text-[10px] font-mono flex items-center justify-center cursor-pointer transition-all ${
                bit === 1 
                  ? 'bg-brand-blue border-brand-blue text-white font-bold' 
                  : 'bg-brand-black border-brand-border text-brand-text-dim'
              }"
              data-bit="${i}"
            >
              ${bit}
            </button>
            <span class="text-[8px] font-mono text-brand-text-dim">${i}</span>
          </div>
        `;
      }
      bitGrid.innerHTML = html;

      // Click event for bit toggling
      document.querySelectorAll('.bit-box').forEach(box => {
        box.addEventListener('click', () => {
          const bitIndex = parseInt(box.getAttribute('data-bit')!);
          // Toggle bit
          currentValue ^= (1 << bitIndex);
          updateDisplays();
        });
      });
    }

    // Refresh HEX, DEC, OCT, BIN display text representations
    function updateDisplays(excludeDec = false) {
      // Force boundary constraints to 32-bit signed
      currentValue = currentValue | 0;

      // Hex
      const unsignedVal = currentValue >>> 0;
      displayHex.value = unsignedVal.toString(16).toUpperCase();

      // Decimal
      if (!excludeDec) {
        displayDec.value = String(currentValue);
      }

      // Octal
      displayOct.value = unsignedVal.toString(8);

      // Binary - space groupings of 4 for legibility
      const binStr = unsignedVal.toString(2).padStart(32, '0');
      const groupedBin = binStr.match(/.{1,4}/g)?.join(' ') || binStr;
      displayBin.value = groupedBin;

      // Sync active board state
      buildBitboard();
    }

    // Direct user input on DEC input field
    displayDec.addEventListener('input', () => {
      const cleanVal = displayDec.value.replace(/[^0-9\-]/g, '');
      currentValue = parseInt(cleanVal || '0', 10) | 0;
      updateDisplays(true); // update other outputs but preserve DEC text cursor
    });

    // Handle button base selector row clicks
    function setupBaseRows() {
      const rows = document.querySelectorAll('.base-row');
      rows.forEach(row => {
        row.addEventListener('click', () => {
          rows.forEach(r => {
            r.classList.replace('border-brand-blue', 'border-brand-border');
            r.querySelector('.base-indicator')?.classList.add('opacity-0');
          });
          row.classList.replace('border-brand-border', 'border-brand-blue');
          row.querySelector('.base-indicator')?.classList.remove('opacity-0');

          activeBase = parseInt(row.getAttribute('data-base')!);
          if (activeBase === 10) {
            displayDec.focus();
          }
          syncKeyboardState();
        });
      });
    }

    // Dynamically enable/disable keyboard keys depending on currently active numerical base mode
    function syncKeyboardState() {
      const keys = document.querySelectorAll('.btn-prog');
      keys.forEach((btn: any) => {
        const key = btn.getAttribute('data-key');
        if (!key) return;

        // Command keys always enabled
        if (['DEL', 'AC', 'toggle-sign'].includes(key) || btn.id === 'btn-save-prog') {
          btn.disabled = false;
          return;
        }

        // Base checks
        const isHexLetter = ['A', 'B', 'C', 'D', 'E', 'F'].includes(key);
        const isDecimalNum = ['8', '9'].includes(key);
        const isOctalNum = ['2', '3', '4', '5', '6', '7'].includes(key);
        const isBinaryNum = ['0', '1'].includes(key);

        if (activeBase === 2) {
          btn.disabled = !isBinaryNum;
        } else if (activeBase === 8) {
          btn.disabled = isHexLetter || isDecimalNum;
        } else if (activeBase === 10) {
          btn.disabled = isHexLetter;
        } else if (activeBase === 16) {
          btn.disabled = false;
        }
      });
    }

    // Handle keypress logic
    function processProgKey(key: string) {
      if (key === 'AC') {
        currentValue = 0;
      } else if (key === 'DEL') {
        // Strip last digit depending on active base mode representation
        let strVal = '';
        const unsignedVal = currentValue >>> 0;
        if (activeBase === 2) strVal = unsignedVal.toString(2);
        else if (activeBase === 8) strVal = unsignedVal.toString(8);
        else if (activeBase === 10) strVal = String(currentValue);
        else if (activeBase === 16) strVal = unsignedVal.toString(16).toUpperCase();

        strVal = strVal.slice(0, -1);
        if (!strVal || strVal === '-') strVal = '0';

        if (activeBase === 10) {
          currentValue = parseInt(strVal, 10);
        } else {
          currentValue = parseInt(strVal, activeBase) | 0;
        }
      } else if (key === 'toggle-sign') {
        currentValue = -currentValue;
      } else {
        // Concatenate digit to existing value
        let strVal = '';
        const unsignedVal = currentValue >>> 0;
        if (activeBase === 2) strVal = unsignedVal.toString(2);
        else if (activeBase === 8) strVal = unsignedVal.toString(8);
        else if (activeBase === 10) strVal = String(currentValue);
        else if (activeBase === 16) strVal = unsignedVal.toString(16).toUpperCase();

        if (strVal === '0') strVal = '';
        strVal += key;

        if (activeBase === 10) {
          currentValue = parseInt(strVal, 10) | 0;
        } else {
          currentValue = parseInt(strVal, activeBase) | 0;
        }
      }
      updateDisplays();
    }

    // Shift / Logic Operator operations
    function setupBitwiseActions() {
      const actions = document.querySelectorAll('.btn-bit-action');
      actions.forEach(btn => {
        btn.addEventListener('click', () => {
          const action = btn.getAttribute('data-action')!;
          if (action === 'not') {
            currentValue = ~currentValue;
          } else if (action === 'lsh') {
            currentValue = currentValue << 1;
          } else if (action === 'rsh') {
            currentValue = currentValue >> 1;
          } else if (action === 'clear') {
            currentValue = 0;
          }
          updateDisplays();
        });
      });

      // Save analysis to history sidebar
      document.getElementById('btn-save-prog')?.addEventListener('click', () => {
        const hex = displayHex.value;
        const dec = displayDec.value;
        const bin = displayBin.value;
        
        window.dispatchEvent(
          new CustomEvent('add-history', {
            detail: { expr: `Base-N (HEX: ${hex})`, result: `DEC: ${dec}, BIN: ${bin.slice(0, 14)}...`, mode: 'programming' }
          })
        );
      });
    }

    // Keyboard bindings
    window.addEventListener('keydown', (e) => {
      // Ignore global shortcuts when explicitly typing in the Decimal field
      if (document.activeElement === displayDec) {
        return;
      }

      const key = e.key.toUpperCase();
      
      // Del & Backspace
      if (e.key === 'Backspace') {
        processProgKey('DEL');
        return;
      }
      if (e.key === 'Escape') {
        processProgKey('AC');
        return;
      }

      // Check key character mappings based on current base rules
      const hexLetters = ['A', 'B', 'C', 'D', 'E', 'F'];
      const decNums = ['8', '9'];
      const octNums = ['2', '3', '4', '5', '6', '7'];
      const binNums = ['0', '1'];

      let valid = false;
      if (activeBase === 2 && binNums.includes(key)) valid = true;
      if (activeBase === 8 && (binNums.includes(key) || octNums.includes(key))) valid = true;
      if (activeBase === 10 && (binNums.includes(key) || octNums.includes(key) || decNums.includes(key))) valid = true;
      if (activeBase === 16 && (binNums.includes(key) || octNums.includes(key) || decNums.includes(key) || hexLetters.includes(key))) valid = true;

      if (valid) {
        processProgKey(key);
      }
    });

    // Handle mouse button clicks
    document.querySelectorAll('.btn-prog[data-key]').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-key')!;
        processProgKey(key);
      });
    });

    // Listen to history load triggers
    window.addEventListener('load-expression', (e: any) => {
      if (e.detail.mode === 'programming') {
        // Can reload value dynamically
        const resultString = e.detail.result;
        const decMatch = resultString.match(/DEC:\s*(-?\d+)/);
        if (decMatch && decMatch[1]) {
          currentValue = parseInt(decMatch[1], 10);
          updateDisplays();
        }
      }
    });

    // Run setup
    setupBaseRows();
    setupBitwiseActions();
    updateDisplays();
    syncKeyboardState();
  </script>
</Layout>

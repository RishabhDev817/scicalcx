---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-brand-border bg-brand-black py-8 px-4 sm:px-6 text-center text-xs sm:text-sm text-brand-text-dim relative">
  <div class="max-w-5xl mx-auto flex flex-col items-center gap-6">
    <!-- Ko-fi Donation Widget Container -->
    <div class="flex flex-col items-center gap-3 w-full">
      <a 
        href="https://ko-fi.com/scicalcx" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="inline-flex items-center gap-2.5 px-6 py-3 rounded-full bg-[#FF5E5B] hover:bg-[#ff4744] text-white font-semibold transition-all duration-300 hover:scale-105 active:scale-95 shadow-lg shadow-[#FF5E5B]/20 hover:shadow-[#FF5E5B]/40 hover:shadow-xl group"
      >
        <!-- Ko-fi SVG Cup Icon -->
        <svg 
          viewBox="0 0 24 24" 
          class="w-5 h-5 fill-white group-hover:scale-110 transition-transform duration-200"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 12.224 10.521 12.03 10.521 12.03 1.905-.008 7.02-.026 8.382-.047 3.874-.3 3.712-4.116 3.712-4.116 1.823-.008 1.942-2.915 1.942-2.915 1.487-.272 1.343-2.98 1.343-2.98.055-1.127-.145-2.002-.145-2.002zm-5.786 8.25s-.834.023-2.186.046c-1.144.02-3.864.04-3.864.04-.51 0-3.14-.08-4.787-1.742-1.721-1.737-1.688-4.996-1.688-4.996.002-.338.005-.688.007-1.048h12.518s.004.997.004 2.531c-.001 2.062-.004 5.169-.004 5.169zm4.38-2.617s-.063.957-.753.978c-.742.024-.742-.998-.742-.998v-3.056s-.065-.89.576-.906c.642-.016.92.883.92.883v3.099z"/>
        </svg>
        <span class="tracking-wide text-xs sm:text-sm font-sans">Support SciCalcX on Ko-fi</span>
      </a>
      <p class="max-w-md text-xs leading-relaxed text-brand-text-muted font-normal mt-1">
        Built by student developers Rishabh and Riya. If SciCalcX saved you time during a lab session, consider supporting the server hosting costs! ☕🚀
      </p>
    </div>

    <!-- Divider Line -->
    <div class="w-full h-px bg-brand-border/60"></div>

    <!-- Bottom Links & Brand -->
    <div class="w-full flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-mono">
      <div class="text-brand-text-muted text-center sm:text-left">
        &copy; {currentYear} SciCalcX. Open-source scientific computational system.
      </div>
      <div class="flex flex-wrap justify-center gap-x-4 gap-y-2">
        <a href="/about" class="hover:text-brand-text transition-colors">About Us</a>
        <span class="text-brand-border-strong">&bull;</span>
        <a href="/contact" class="hover:text-brand-text transition-colors">Contact Us</a>
        <span class="text-brand-border-strong">&bull;</span>
        <a href="/terms" class="hover:text-brand-text transition-colors">Terms &amp; Conditions</a>
        <span class="text-brand-border-strong">&bull;</span>
        <a href="/privacy" class="hover:text-brand-text transition-colors">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>

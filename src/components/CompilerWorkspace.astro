          This document was automatically generated by SciCalcX Compiler Sandbox. All executions simulated on Wandbox.
        </div>
      `;

      // 1. Attach to DOM
      document.body.appendChild(tempContainer);

      // Temporarily disable global/cross-origin stylesheets to prevent html2canvas crashes on modern CSS parsing
      try {
        const stylesAndLinks = document.querySelectorAll('link[rel="stylesheet"], style');
        stylesAndLinks.forEach((el) => {
          if (el.parentNode === tempContainer || el.closest('#temp-export-container')) {
            return;
          }
          const sheetEl = el as HTMLLinkElement | HTMLStyleElement;
          disabledSheets.push({
            sheet: sheetEl,
            wasEnabled: !sheetEl.disabled
          });
          sheetEl.disabled = true;
        });
      } catch (styleErr) {
        console.warn('Style pre-processing warning:', styleErr);
      }

      // 3. Await Capture
      const canvas = await html2canvasLib(tempContainer, {
        scale: 2,
        useCORS: true,
        logging: false,
        backgroundColor: '#ffffff'
      });

      const imgData = canvas.toDataURL('image/png');
      const link = document.createElement('a');
      const safeName = studentName.replace(/[^a-zA-Z0-9_-]/g, '_');
      link.download = `${safeName}_Assignment.png`;
      link.href = imgData;
      link.click();

      closeExportModal();
    } catch (err: any) {
      console.error(err);
      alert('Error rendering assignment image: ' + (err.message || err));
    } finally {
      // Restore disabled stylesheets
      try {
        disabledSheets.forEach(({ sheet, wasEnabled }) => {
          sheet.disabled = !wasEnabled;
        });
      } catch (restoreErr) {
        console.error('Style post-processing restore warning:', restoreErr);
      }

      if (tempContainer && tempContainer.parentNode) {
        document.body.removeChild(tempContainer);
      }
      btnGenerateImage.disabled = false;
      btnGenerateText.innerHTML = originalText;
    }
  });

  // Vertical resizing logic for console containers
  function makeVerticalResizable(resizerId, containerId, isBottomElement = true) {
    const resizer = document.getElementById(resizerId);
    const container = document.getElementById(containerId);
    if (!resizer || !container) return;

    resizer.addEventListener('mousedown', (e) => {
      e.preventDefault();
      const startY = e.clientY;
      const startHeight = container.getBoundingClientRect().height;

      function onMouseMove(moveEvent) {
        const deltaY = moveEvent.clientY - startY;
        const newHeight = isBottomElement ? startHeight - deltaY : startHeight + deltaY;
        
        // Boundaries: minimum height of 60px, max of 600px
        if (newHeight >= 60 && newHeight <= 600) {
          container.style.height = `${newHeight}px`;
        }
      }

      function onMouseUp() {
        document.removeEventListener('mousemove', onMouseMove);
        document.removeEventListener('mouseup', onMouseUp);
      }

      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('mouseup', onMouseUp);
    });
  }

  // Initialize resizable terminals
  makeVerticalResizable('normal-terminal-resizer', 'normal-terminal-container', true);
  makeVerticalResizable('fullscreen-terminal-resizer', 'fullscreen-terminal-pane', true);

  // Run Startup
  initWorkspace();

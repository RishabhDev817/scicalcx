            executeCodeWithInputs(code, stdinBuffer, gatheredInputs);
          }
        });
      }
      
      collectNextInput();
    } else {
      printToTerminal(`<span id="terminal-loading" class="text-brand-blue-neon font-mono">// Sandbox compiling and executing script...</span>\n`, false);
      executeCodeWithInputs(code, "", []);

  // Debounced persistence saving
  let saveDebounceTimer;
  function saveDraftCode(lessonId, subId, language, code) {
    clearTimeout(saveDebounceTimer);
    saveDebounceTimer = setTimeout(() => {
      if (isSandboxMode) {
        localStorage.setItem(`scicalcx_sandbox_draft_${language}`, code);
      } else {
        localStorage.setItem(`scicalcx_code_draft_${lessonId}_${subId}_${language}`, code);

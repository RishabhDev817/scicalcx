  // Switch Lesson Node
  function switchLesson(lessonId, animate = true) {
    activeLessonId = lessonId;
    localStorage.setItem('scicalcx_active_lesson', String(lessonId));
    
    const lesson = lessons.find(l => l.id === lessonId)!;

    // Load subId from cache or locate first incomplete sub
    const completedSubs = completedSubChallenges[lessonId] || [];
    const firstIncomplete = lesson.challenges.find(c => !completedSubs.includes(c.subId));
    
    let targetSubId = 0;
    if (firstIncomplete) {
      targetSubId = firstIncomplete.subId;
    } else {
      targetSubId = 0;
    }

    const savedSub = localStorage.getItem('scicalcx_active_sub');
    if (savedSub !== null && lesson.challenges.some(c => c.subId === parseInt(savedSub, 10))) {
      targetSubId = parseInt(savedSub, 10);
    }

    activeSubId = targetSubId;
    localStorage.setItem('scicalcx_active_sub', String(targetSubId));

    const challenge = lesson.challenges.find(c => c.subId === targetSubId)!;
    
    // Update labels
    document.getElementById('lesson-title')!.textContent = challenge.title;
    document.getElementById('lesson-instruction')!.textContent = challenge.instruction;
    document.getElementById('lesson-criteria')!.textContent = challenge.successCriteria;
    
    // Populate code draft or load template
    const savedDraft = localStorage.getItem(`scicalcx_code_draft_${lessonId}_${targetSubId}_${activeLanguage}`);
    if (savedDraft !== null) {
      codeEditor.value = savedDraft;
    } else {
      codeEditor.value = challenge.templates[activeLanguage];
    }
    
    // Update tutoring
    document.getElementById('tutor-breakdown')!.innerHTML = challenge.breakdown[activeLanguage];
    document.getElementById('tutor-analogy')!.textContent = challenge.analogy[activeLanguage];
    
    // Reset bug dashboard
    resetBugCard();
    
    updateLineNumbers();
    renderProgressMap();
    renderSubChallengeTabs();
    
    if (animate) {
      printToTerminal(`<span class="text-brand-text-dim">// Switched to topic: ${lesson.title}. Ready.</span>`, true);
    }
  }


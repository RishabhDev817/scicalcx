  // Local Diagnostic Simulator (LDS) for when Piston / Wandbox API requires fallback
  function runLocalSimulation(code, language, lessonId, subId, gatheredInputs = []) {
    const lines = code.split('\n');
    let stdout = "";
    let stderr = "";
    
    // 1. Universal C and C++ validation rules
    if (language === 'c' || language === 'cpp') {
      if (code.includes('void main')) {
        return {
          stdout: "",
          stderr: `main.cpp:2:1: error: '::main' must return 'int'`
        };
      }
      
      let inBlockComment = false;
      for (let i = 0; i < lines.length; i++) {
        let line = lines[i].trim();
        
        if (inBlockComment) {
          if (line.includes('*/')) {
            line = line.substring(line.indexOf('*/') + 2).trim();
            inBlockComment = false;
          } else {
            continue;
          }
        }
        
        if (line.includes('/*')) {
          if (line.includes('*/')) {
            line = line.replace(/\/\*[\s\S]*?\*\//g, '').trim();
          } else {
            line = line.substring(0, line.indexOf('/*')).trim();
            inBlockComment = true;
          }
        }
        
        // Strip single-line comments
        if (line.includes('//')) {
          line = line.substring(0, line.indexOf('//')).trim();
        }
        
        if (!line || line.startsWith('#')) continue;
        
        // Valid statement/block endings in C/C++
        const validEndings = [';', '{', '}', ':', ',', '\\', '(', '['];
        const lastChar = line.slice(-1);
        if (validEndings.includes(lastChar)) continue;
        
        // Skip control structures and function/struct headers
        if (/^(if|else|for|while|do|switch|case|default|struct|class|enum|namespace|using|template)\b/.test(line)) continue;
        if (/^\w+.*\(.*\)$/.test(line) && !line.includes('=')) continue;
        
        // Check for statements requiring semicolons
        if (/\b(printf|cout|cin|return|scanf)\b/.test(line) || /^\w+\s+(\w+)\s*=/.test(line) || /^(int|float|double|char|long|short|bool|auto|string|let|var)\s+\w+/.test(line)) {
          return {
            stdout: "",
            stderr: `main.cpp:${i + 1}:${Math.max(1, line.length)}: error: expected ';' before end of line`
          };
        }
      }
    }
    
    // 2. Universal Python validation rules
    if (language === 'python') {
      for (let i = 0; i < lines.length; i++) {
        const rawLine = lines[i];
        const lineWithoutComment = rawLine.split('#')[0].trim();
        if (!lineWithoutComment) continue;
        
        if ((lineWithoutComment.startsWith('if ') || lineWithoutComment.startsWith('else') || lineWithoutComment.startsWith('for ') || lineWithoutComment.startsWith('while ')) && !lineWithoutComment.endsWith(':')) {
          return {
            stdout: "",
            stderr: `  File "main.py", line ${i + 1}\n    ${lines[i]}\n    SyntaxError: expected ':'`
          };
        }
      }
      
      for (let i = 0; i < lines.length - 1; i++) {
        const line = lines[i].split('#')[0].trim();
        const nextLine = lines[i+1];
        if (line.endsWith(':') && nextLine.trim() !== "" && !nextLine.startsWith(' ') && !nextLine.startsWith('\t')) {
          return {
            stdout: "",
            stderr: `  File "main.py", line ${i + 2}\n    ${nextLine.trim()}\nIndentationError: expected an indented block after control statement on line ${i + 1}`
          };
        }
      }
    }
    
    // 3. Execute arbitrary JS logic simulation
    let jsCode = "";
    let logs: string[] = [];
    const mockPrint = (...args) => {
      logs.push(args.map(a => typeof a === 'object' ? JSON.stringify(a) : String(a)).join(' '));
    };

    let inputIdx = 0;
    const mockInput = () => {
      const val = gatheredInputs[inputIdx] !== undefined ? gatheredInputs[inputIdx] : "";
      inputIdx++;
      return val;
    };

    try {
      if (language === 'python') {
        const preprocessed = convertPythonIndentationToBraces(code);
        const codeLines = preprocessed.split('\n');
        
        for (let i = 0; i < codeLines.length; i++) {
          let line = codeLines[i];
          const trimmed = line.trim();
          
          if (trimmed === "") {
            jsCode += "\n";
            continue;
          }
          
          // Print statements
          if (trimmed.startsWith('print(')) {
            line = line.replace(/print\((.*)\)/g, 'mockPrint($1)');
          } else if (trimmed.startsWith('print ') || trimmed === 'print') {
            line = line.replace(/print\s+(.*)/g, 'mockPrint($1)');
          }
          
          // Loops
          if (trimmed.startsWith('for ') && trimmed.includes('in range(')) {
            const match = trimmed.match(/for\s+(\w+)\s+in\s+range\((.*)\)\s*:/);
            if (match) {
              const varName = match[1];
              const rangeArgs = match[2].split(',').map(s => s.trim());
              let start = "0";
              let end = "0";
              let step = "1";
              
              if (rangeArgs.length === 1) {
                end = rangeArgs[0];
              } else if (rangeArgs.length === 2) {
                start = rangeArgs[0];
                end = rangeArgs[1];
              } else if (rangeArgs.length === 3) {
                start = rangeArgs[0];
                end = rangeArgs[1];
                step = rangeArgs[2];
              }
              
              const indent = line.length - line.trimStart().length;
              line = " ".repeat(indent) + `for (let ${varName} = ${start}; ${varName} < ${end}; ${varName} += ${step}) {`;
            }
          }
          
          // Conditionals
          if (trimmed.startsWith('if ') && trimmed.endsWith(':')) {
            const cond = trimmed.slice(3, -1).replace(/\band\b/g, '&&').replace(/\bor\b/g, '||');
            const indent = line.length - line.trimStart().length;
            line = " ".repeat(indent) + `if (${cond}) {`;
          }
          if (trimmed.startsWith('elif ') && trimmed.endsWith(':')) {
            const cond = trimmed.slice(5, -1).replace(/\band\b/g, '&&').replace(/\bor\b/g, '||');
            const indent = line.length - line.trimStart().length;
            line = " ".repeat(indent) + `} else if (${cond}) {`;
          }
          if (trimmed === 'else:') {
            const indent = line.length - line.trimStart().length;
            line = " ".repeat(indent) + `} else {`;
          }
          
          jsCode += line + "\n";
        }
      } else {
        // C and C++ JS conversion
        let codeBody = code;
        codeBody = codeBody.replace(/#include\s*<.*>/g, '');
        codeBody = codeBody.replace(/using\s+namespace\s+std\s*;/g, '');
        codeBody = codeBody.replace(/\binline\b/g, '');
        
        // Convert C/C++ function definitions to JS functions
        codeBody = codeBody.replace(/\b(int|double|float|char|void|long|short|auto|bool|string)\s+(\w+)\s*\(([^)]*)\)\s*\{/g, (match, retType, fnName, params) => {
          if (fnName === 'main') return 'function main() {';
          const cleanParams = params.split(',').map(p => p.trim().replace(/^.*?\b(\w+)$/, '$1')).join(', ');
          return `function ${fnName}(${cleanParams}) {`;
        });
        
        // Convert cout streams (single or chained)
        codeBody = codeBody.replace(/(?:std::)?cout\s*<<\s*([\s\S]*?);/g, (match, expr) => {
          const parts = expr.split('<<').map(p => p.trim()).filter(p => p && p !== 'endl' && p !== 'std::endl');
          if (parts.length === 0) return '';
          return `mockPrint(${parts.join(', ')});`;
        });
        
        // Convert printf formatting
        codeBody = codeBody.replace(/printf\s*\(\s*"(.*?)"\s*(?:,\s*(.*?))?\s*\)\s*;/g, (match, format, args) => {
          if (args) {
            return `mockPrint(${args});`;
          }
          const clean = format.replace(/\\n/g, '');
          return `mockPrint("${clean}");`;
        });
        
        // Convert scanf mock replacement
        codeBody = codeBody.replace(/scanf\s*\(\s*"[^"]*"\s*,\s*&(\w+)\s*\)\s*;/g, '$1 = Number(mockInput());');
        
        // Convert chained or single cin >> var1 >> var2...
        codeBody = codeBody.replace(/(?:std::)?cin\s*((?:\s*>>\s*[a-zA-Z0-9_\[\]\.\->]+)+)\s*;/g, (match, chain) => {
          const vars = chain.split('>>').map(v => v.trim()).filter(Boolean);
          return vars.map(v => `${v} = Number(mockInput());`).join(' ');
        });

        // Convert variable declarations
        codeBody = codeBody.replace(/\b(int|double|float|char|long|short|bool|auto)\s+([a-zA-Z_]\w*(?:\s*,\s*[a-zA-Z_]\w*)*\s*(?:=[^;]+)?);/g, 'let $2;');
        
        codeBody = codeBody.replace(/return\s+0\s*;/g, '');
        
        jsCode = codeBody + "\nif (typeof main === 'function') main();";
      }
      
      const runFn = new Function('mockPrint', 'mockInput', 'input', jsCode);
      runFn(mockPrint, mockInput, mockInput);
      
      stdout = logs.join('\n') + (logs.length > 0 ? '\n' : '');
    } catch (err: any) {
      let msg = err.message;
      stderr = msg.includes('is not defined') ? `NameError: ${msg}` : `SyntaxError: ${msg}`;
    }
    
    return { stdout, stderr };
  }
  
  function convertPythonIndentationToBraces(code) {
    const lines = code.split('\n');
    let result = "";
    let indentStack = [0];
    
    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];
      const trimmed = line.trim();
      if (trimmed === "") {
        result += "\n";
        continue;
      }
      
      const indent = line.length - line.trimStart().length;
      
      while (indent < indentStack[indentStack.length - 1]) {
        indentStack.pop();
        const prevIndent = indentStack[indentStack.length - 1] || 0;
        result += " ".repeat(prevIndent) + "}\n";
      }
      
      if (indent > indentStack[indentStack.length - 1]) {
        indentStack.push(indent);
      }
      
      result += line + "\n";
    }
    
    while (indentStack.length > 1) {
      indentStack.pop();
      const prevIndent = indentStack[indentStack.length - 1] || 0;
      result += " ".repeat(prevIndent) + "}\n";
    }
    
    return result;
  }

  // Dynamic stdin parser counting input commands
  function countInputsNeeded(code, language) {
    let count = 0;
    let cleanCode = code;
    if (language === 'python') {
      cleanCode = code.replace(/#.*$/gm, '');
    } else {
      cleanCode = code.replace(/\/\/.*$/gm, '').replace(/\/\*[\s\S]*?\*\//g, '');
    }

    if (language === 'cpp') {
      const cinRegex = /cin\s*(>>\s*[a-zA-Z_0-9\[\]\(\)\.\->]+)+/g;
      let match;
      while ((match = cinRegex.exec(cleanCode)) !== null) {
        const extractions = match[0].match(/>>/g);
        if (extractions) {
          count += extractions.length;
        }
      }
    } else if (language === 'c') {
      const scanfRegex = /scanf\s*\(\s*"([^"]*)"/g;
      let match;
      while ((match = scanfRegex.exec(cleanCode)) !== null) {
        const formatStr = match[1];
        const specifiers = formatStr.match(/%[a-zA-Z]/g);
        if (specifiers) {
          count += specifiers.length;
        }
      }
    } else if (language === 'python') {
      const inputRegex = /\binput\s*\(/g;
      const matches = cleanCode.match(inputRegex);
      if (matches) {
        count = matches.length;
      }
    }
    return count;
  }

  // Guesses prompts preceding inputs
  function getPromptForInput(code, language, inputIndex) {
    let cleanCode = code;
    if (language === 'python') {
      cleanCode = code.replace(/#.*$/gm, '');
      const inputRegex = /input\s*\(\s*(['"])(.*?)\1\s*\)/g;
      let match;
      let idx = 0;
      while ((match = inputRegex.exec(cleanCode)) !== null) {
        if (idx === inputIndex) {
          return match[2];
        }
        idx++;
      }
    } else if (language === 'cpp') {
      const statements = cleanCode.split(';');
      let cinCount = 0;
      for (let s = 0; s < statements.length; s++) {
        if (statements[s].includes('cin')) {
          if (cinCount === inputIndex) {
            if (s > 0 && statements[s-1].includes('cout')) {
              const coutStrMatch = statements[s-1].match(/"([^"]*)"/);
              if (coutStrMatch) return coutStrMatch[1];
            }
          }
          cinCount++;
        }
      }
    } else if (language === 'c') {
      const statements = cleanCode.split(';');
      let scanfCount = 0;
      for (let s = 0; s < statements.length; s++) {
        if (statements[s].includes('scanf')) {
          if (scanfCount === inputIndex) {
            if (s > 0 && statements[s-1].includes('printf')) {
              const printfStrMatch = statements[s-1].match(/"([^"]*)"/);
              if (printfStrMatch) return printfStrMatch[1];
            }
          }
          scanfCount++;
        }
      }
    }
    return `Enter input [${inputIndex + 1}]: `;
  }

  // Interactive Pseudo-Terminal Stdin Prompt UI
  function promptForStdin(promptText, index, total, onComplete) {
    const isFullscreen = editorCard.classList.contains('editor-fullscreen');
    const activeTerminal = isFullscreen ? fullscreenTerminalContent : terminalContent;
    const inputId = `interactive-stdin-${index}`;
    
    // Print the prompt with a clean seamless inline input box
    const html = `
      <span id="wrapper-${inputId}" class="inline-flex items-center space-x-1 font-mono text-sm text-slate-600 dark:text-slate-300">
        <span>${escapeHTML(promptText)}</span>
        <input 
          type="text" 
          id="${inputId}" 
          class="bg-transparent border-none outline-none text-brand-blue dark:text-brand-blue-neon focus:ring-0 p-0 m-0 font-mono text-sm caret-slate-800 dark:caret-white w-24" 
          style="border: none !important; outline: none !important; box-shadow: none !important;"
          autocomplete="off"
        />
      </span>
    `;
    
    activeTerminal.insertAdjacentHTML('beforeend', html);
    activeTerminal.scrollTop = activeTerminal.scrollHeight;
    
    const inputEl = document.getElementById(inputId) as HTMLInputElement;
    if (inputEl) {
      inputEl.focus();
      
      const clickFocusHandler = () => inputEl.focus();
      activeTerminal.addEventListener('click', clickFocusHandler);
      
      inputEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const value = inputEl.value;
          activeTerminal.removeEventListener('click', clickFocusHandler);
          
          const wrapper = document.getElementById(`wrapper-${inputId}`);
          if (wrapper) {
            wrapper.outerHTML = `<span>${escapeHTML(promptText)}</span><span class="text-brand-blue dark:text-brand-blue-neon ml-1 font-bold">${escapeHTML(value)}</span>\n`;
          }
          
          onComplete(value);
        }
      });
    }
  }

  // Execution wrapper sending code and gathered stdin buffer
  async function executeCodeWithInputs(code, stdinValue, gatheredInputs = []) {
    try {
      let stdout = "";
      let stderr = "";
      let simulated = false;
      
      try {
        let compilerName = "cpython-3.13.8";
        if (activeLanguage === 'c') {
          compilerName = "gcc-13.2.0-c";
        } else if (activeLanguage === 'cpp') {
          compilerName = "gcc-13.2.0";
        }
        
        const response = await fetch("https://wandbox.org/api/compile.json", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            compiler: compilerName,
            code: code,
            stdin: stdinValue
          })
        });
        
        if (!response.ok) {
          simulated = true;
        } else {
          const res = await response.json();
          stdout = res.program_output || "";
          
          if (res.compiler_error) {
            stderr = res.compiler_error;
          } else if (res.program_error) {
            stderr = res.program_error;
          } else if (!stdout && res.compiler_message) {
            stderr = res.compiler_message;
          }
        }
      } catch (netError) {
        simulated = true;
      }
      
      // Remove loading indicator elements safely from DOM before appending results
      const loaders = document.querySelectorAll('#terminal-loading');
      loaders.forEach(l => l.remove());
      
      if (simulated) {
        console.warn("[LDS] Wandbox API unavailable. Falling back to local diagnostic simulator.");
        const sim = runLocalSimulation(code, activeLanguage, activeLessonId, activeSubId, gatheredInputs);
        stdout = sim.stdout;
        stderr = sim.stderr;
      }
      
      let prefixHTML = "";
      if (simulated) {
        prefixHTML = `<span class="text-brand-blue-neon font-mono">// [LOCAL DIAGNOSTIC SIMULATOR ACTIVE]</span>\n`;
      }

      // Reconstruct the exact chronological log (Prompt -> User Input -> Prompt -> User Input -> Final Result) without duplication
      let reconstructedHTML = prefixHTML;
      let remainingStdout = stdout;
      
      for (let i = 0; i < gatheredInputs.length; i++) {
        const userVal = gatheredInputs[i];
        
        // Search for the first matching prompt among all remaining prompts starting from i
        let firstFoundPromptIdx = -1;
        let firstFoundMatchPos = -1;
        let firstFoundMatchLength = 0;
        let matchedPromptText = "";
        
        for (let k = i; k < gatheredInputs.length; k++) {
          const prompt = getPromptForInput(code, activeLanguage, k);
          const isFallback = prompt.startsWith("Enter input [") && prompt.endsWith("]: ");
          if (isFallback) continue;
          
          let pos = remainingStdout.indexOf(prompt);
          let len = prompt.length;
          
          if (pos === -1) {
            const trimmed = prompt.trim();
            if (trimmed) {
              pos = remainingStdout.indexOf(trimmed);
              len = trimmed.length;
            }
          }
          
          if (pos !== -1) {
            if (firstFoundMatchPos === -1 || pos < firstFoundMatchPos) {
              firstFoundMatchPos = pos;
              firstFoundPromptIdx = k;
              firstFoundMatchLength = len;
              matchedPromptText = prompt;
            }
          }
        }
        
        if (firstFoundPromptIdx !== -1) {
          if (firstFoundPromptIdx === i) {
            // The prompt belongs to the current input
            const beforePrompt = remainingStdout.substring(0, firstFoundMatchPos);
            if (beforePrompt) {
              reconstructedHTML += `<span>${escapeHTML(beforePrompt)}</span>`;
            }
            reconstructedHTML += `<span>${escapeHTML(matchedPromptText)}</span><span class="text-brand-blue dark:text-brand-blue-neon font-bold">${escapeHTML(userVal)}</span>\n`;
            remainingStdout = remainingStdout.substring(firstFoundMatchPos + firstFoundMatchLength);
          } else {
            // The prompt belongs to a future input k.
            // This means everything in remainingStdout up to firstFoundMatchPos belongs to the current input i.
            const promptForCurrent = remainingStdout.substring(0, firstFoundMatchPos);
            reconstructedHTML += `<span>${escapeHTML(promptForCurrent)}</span><span class="text-brand-blue dark:text-brand-blue-neon font-bold">${escapeHTML(userVal)}</span>\n`;
            remainingStdout = remainingStdout.substring(firstFoundMatchPos);
          }
        } else {
          // No prompts found in remainingStdout.
          if (remainingStdout) {
            reconstructedHTML += `<span>${escapeHTML(remainingStdout)}</span><span class="text-brand-blue dark:text-brand-blue-neon font-bold">${escapeHTML(userVal)}</span>\n`;
            remainingStdout = "";
          } else {
            const fallbackPrompt = getPromptForInput(code, activeLanguage, i);
            reconstructedHTML += `<span>${escapeHTML(fallbackPrompt)}</span><span class="text-brand-blue dark:text-brand-blue-neon font-bold">${escapeHTML(userVal)}</span>\n`;
          }
        }
      }
      
      if (remainingStdout) {
        reconstructedHTML += `<span>${escapeHTML(remainingStdout)}</span>`;
      }

      if (stderr) {
        reconstructedHTML += `<span class="text-red-500">${escapeHTML(stderr)}</span>`;
        printToTerminal(reconstructedHTML, true);
        const errorDetail = translateError(stderr, activeLanguage);
        if (errorDetail) {
          showBugCard(errorDetail.explanation, errorDetail.solution);
        } else {
          showBugCard("Execution Error", "Your script encountered a runtime crash. Please check the logs.");
        }
      } else {
        if (reconstructedHTML) {
          printToTerminal(reconstructedHTML, true);
        } else {
          printToTerminal(`<span class="text-brand-text-dim">// Script ran successfully but generated empty output.</span>`, true);
        }
        resetBugCard();
        
        if (isSandboxMode) {
          printToTerminal(`\n\n<span class="text-emerald-400 font-bold font-mono">🎉 PLAYGROUND RUN COMPLETED</span>`, false);
        } else {
          const activeLesson = lessons.find(l => l.id === activeLessonId)!;
          const activeChallenge = activeLesson.challenges.find(c => c.subId === activeSubId)!;
          const passed = activeChallenge.validate(stdout);
          
          if (passed) {
            if (!completedSubChallenges[activeLessonId]) {
              completedSubChallenges[activeLessonId] = [];
            }
            if (!completedSubChallenges[activeLessonId].includes(activeSubId)) {
              completedSubChallenges[activeLessonId].push(activeSubId);
              localStorage.setItem('scicalcx_completed_subs', JSON.stringify(completedSubChallenges));
            }
            printToTerminal(`\n\n<span class="text-emerald-400 font-bold font-mono">🎉 SUCCESS: Exercise requirements satisfied!</span>`, false);
            
            const lessonCompleted = isLessonCompleted(activeLessonId);
            if (lessonCompleted) {
              printToTerminal(`\n<span class="text-emerald-400 font-bold font-mono">🏆 TOPIC COMPLETED: You passed all challenges for "${activeLesson.title}"!</span>`, false);
              const nextIndex = lessons.findIndex(l => l.id === activeLessonId) + 1;
              if (nextIndex < lessons.length) {
                printToTerminal(`\n<span class="text-brand-blue-neon font-mono">🔓 New Topic Unlocked: "${lessons[nextIndex].shortTitle}". Click it above to continue!</span>`, false);
              } else {
                printToTerminal(`\n<span class="text-amber-400 font-bold font-mono">🥇 CONGRATULATIONS! You have completed all lessons in the Track!</span>`, false);
              }
            } else {
              const nextIncomplete = activeLesson.challenges.find(c => !(completedSubChallenges[activeLessonId] || []).includes(c.subId));
              if (nextIncomplete) {
                printToTerminal(`\n<span class="text-brand-blue-neon font-mono">👉 Next Exercise: "${nextIncomplete.title}". Select it above to start!</span>`, false);
              }
            }
            
            window.dispatchEvent(
              new CustomEvent('add-history', {
                detail: {
                  expr: `Learn Path: ${activeLesson.shortTitle} - ${activeChallenge.title} (${activeLanguage.toUpperCase()})`,
                  result: `PASSED`,
                  mode: 'compiler'
                }
              })
            );
            
            incrementStreak();
            renderProgressMap();
            renderSubChallengeTabs();
          } else {
            printToTerminal(`\n\n<span class="text-brand-text-dim">// Check warning: Program ran but output did not match requirements.</span>\n<span class="text-brand-text-dim">Required target: ${activeChallenge.successCriteria}</span>`, false);
          }
        }
      }
    } catch (e: any) {
      printToTerminal(`<span class="text-red-500">API Connection Failed: ${escapeHTML(e.message)}</span>`, false);
      showBugCard("API Connection Issue", "Unable to execute code. Verify internet connection status or retry later.");
    } finally {
      btnRunCode.disabled = false;
      btnRunCode.classList.remove('opacity-75', 'cursor-wait');
      btnRunText.textContent = "RUN CODE";
      btnRunIcon.innerHTML = "▶";
    }
  }


---
// CompilerWorkspace.astro
// Advanced Gamified Step-by-Step Learning Track, Compiler, and AI Tutor for SciCalcX
---

<div class="w-full max-w-6xl mx-auto space-y-6 animate-fade-in">
  <!-- Workspace Header -->
  <div class="text-center md:text-left space-y-1.5 border-b border-brand-border/60 pb-4">
    <div class="text-[10px] font-mono uppercase tracking-widest text-brand-blue-neon flex items-center justify-center md:justify-start gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-brand-blue-neon animate-pulse"></span>
      Interactive Learning Playground
    </div>
    <h1 class="text-3xl font-bold tracking-tight text-brand-text">
      AI Coding Tutor & Compiler<span class="text-brand-blue">.</span>
    </h1>
    <p class="text-xs text-brand-text-muted">
      Select a lesson, write your solution in Python, C, or C++, and execute instantly using our sandbox executor.
    </p>
  </div>

  <!-- Dual-Panel Grid layout -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch">
    <!-- Left Panel: Learning Track -->
    <div class="lg:col-span-4 flex flex-col space-y-4">
      <div class="border border-slate-200 dark:border-slate-800 bg-white dark:bg-brand-gray-dark/40 rounded-xl p-5 shadow-xl flex flex-col flex-1">
        
        <!-- Workspace Mode Segment Control Toggle -->
        <div class="flex bg-slate-100 dark:bg-brand-black/60 p-1 rounded-lg border border-slate-200 dark:border-brand-border/80 mb-4 font-mono text-[10px] select-none">
          <button 
            id="btn-mode-lessons" 
            class="flex-1 py-1.5 text-center rounded-md font-bold transition-all cursor-pointer bg-brand-blue/10 dark:bg-brand-blue/20 text-brand-blue dark:text-brand-blue-neon border border-brand-blue/30"
          >
            Guided Lessons
          </button>
          <button 
            id="btn-mode-sandbox" 
            class="flex-1 py-1.5 text-center rounded-md font-bold transition-all cursor-pointer text-slate-500 hover:text-slate-800 dark:text-slate-400 dark:hover:text-slate-200 hover:bg-slate-200/50 dark:hover:bg-brand-gray-hover"
          >
            Practice Playground
          </button>
        </div>

        <!-- Roadmap nodes tree container -->
        <div id="progress-map-container" class="flex flex-col flex-1">
          <div class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 pb-4 mb-4">
            <div class="space-y-0.5">
              <h2 class="text-xs font-mono font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-400">
                Course Roadmap
              </h2>
              <span class="text-[9px] text-slate-400 dark:text-slate-500 uppercase font-mono">Click unlocked nodes</span>
            </div>
            
            <!-- Streak Indicator -->
            <div class="flex items-center space-x-1.5 bg-amber-500/10 border border-amber-500/30 rounded-lg px-2.5 py-1">
              <span class="text-[11px] font-mono font-bold text-amber-500 dark:text-amber-400" id="streak-count-text">0 Days 🔥</span>
            </div>
          </div>

          <!-- Node Map Area -->
          <div class="relative pl-1 py-2 flex-1">
            <!-- Central connecting line -->
            <div class="absolute left-[15px] top-6 bottom-6 w-[2px] bg-slate-200 dark:bg-brand-border/60 z-0"></div>
            
            <!-- Progress Tree Nodes -->
            <div class="space-y-5 relative z-10" id="progress-map">
              <!-- Rendered dynamically by Client-Side JS -->
            </div>
          </div>
        </div>

        <!-- Current Active Lesson Instructions -->
        <div class="border border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-brand-black/40 rounded-lg p-4 space-y-3 font-mono text-xs mt-4">
          <div class="text-[10px] text-slate-400 dark:text-slate-500 uppercase tracking-wider border-b border-slate-200 dark:border-slate-800/40 pb-1.5 flex justify-between items-center">
            <span>Lesson Target</span>
            <span id="lesson-criteria" class="text-brand-blue dark:text-brand-blue-neon font-semibold text-[9px] lowercase bg-brand-blue/5 dark:bg-brand-blue/10 border border-brand-blue/20 dark:border-brand-blue/30 px-1.5 py-0.5 rounded">Criteria</span>
          </div>
          
          <!-- Sub-challenge Selector Tabs -->
          <div class="flex flex-wrap gap-1 bg-slate-100 dark:bg-brand-black/60 p-1 rounded border border-slate-200 dark:border-slate-800 mb-2" id="sub-challenge-tabs">
            <!-- Populated dynamically by script -->
          </div>
          
          <h3 id="lesson-title" class="text-sm font-bold text-slate-800 dark:text-slate-200">
            Loading Lesson...
          </h3>
          <p id="lesson-instruction" class="text-slate-600 dark:text-slate-400 leading-relaxed text-[11px] whitespace-pre-line">
            Instructions loading...
          </p>
        </div>
      </div>
    </div>

    <!-- Right Panel: Code Workspace -->
    <div class="lg:col-span-8 flex flex-col space-y-4">
      <!-- Editor Card -->
      <div 
        id="editor-card" 
        class="border border-gray-300 dark:border-gray-700 bg-white dark:bg-[#090d13] rounded-xl overflow-hidden flex flex-col h-[400px] shadow-xl transition-all duration-300 relative"
      >
        <!-- Editor Header Tab -->
        <div class="bg-slate-50 dark:bg-slate-900 border-b border-gray-300 dark:border-gray-700 px-4 py-2 flex items-center justify-between select-none">
          <div class="flex items-center space-x-3">
            <span class="w-2 h-2 rounded-full bg-brand-blue-neon animate-pulse"></span>
            <span class="text-xs font-semibold text-gray-800 dark:text-gray-200 uppercase font-mono tracking-wider">Source Editor</span>
            <span id="save-indicator" class="text-[9px] text-emerald-400 font-mono transition-opacity duration-300 opacity-0 select-none">● Saved draft</span>
          </div>
          
          <div class="flex items-center space-x-2">
            <!-- Header Run Button -->
            <button 
              id="btn-run-code-header" 
              class="px-2.5 py-1 text-[10px] bg-brand-blue hover:bg-brand-blue-hover text-white rounded font-mono font-bold transition-all focus:outline-none cursor-pointer flex items-center gap-1 select-none"
              title="Run code output"
            >
              <span>▶</span>
              <span>RUN</span>
            </button>

            <!-- Reset Button -->
            <button 
              id="btn-reset-code" 
              class="text-[10px] px-2.5 py-1 border border-gray-300 bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-800 dark:border-gray-700 dark:bg-slate-900 dark:hover:bg-slate-800 dark:text-gray-200 dark:hover:text-white rounded font-mono transition-colors focus:outline-none cursor-pointer"
              title="Reset template back to default code"
            >
              Reset Code
            </button>
            
            <!-- Language Dropdown -->
            <select 
              id="select-language" 
              class="bg-white border border-gray-300 text-gray-800 dark:bg-slate-900 dark:border-gray-700 dark:text-gray-200 text-xs rounded px-2.5 py-1 font-mono focus:outline-none focus:border-brand-blue cursor-pointer"
            >
              <option value="python">Python 3</option>
              <option value="c">C (GCC)</option>
              <option value="cpp">C++ (GCC)</option>
            </select>

            <!-- Fullscreen Enlarge Toggle Icon Button -->
            <button 
              id="btn-toggle-fullscreen" 
              class="p-1.5 border border-gray-300 dark:border-gray-700 bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-800 dark:bg-slate-900 dark:hover:bg-slate-800 dark:text-gray-200 dark:hover:text-white rounded-md transition-all focus:outline-none cursor-pointer flex items-center justify-center hover:scale-105 active:scale-95"
              title="Toggle Fullscreen Editor"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path id="fullscreen-path" stroke-linecap="round" stroke-linejoin="round" d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
              </svg>
            </button>
          </div>
        </div>
        
        <!-- Editor Body: Side-by-Side Gutter + Textarea -->
        <div class="flex-1 flex overflow-hidden relative font-mono text-sm">
          <!-- Gutter Column -->
          <div 
            id="editor-gutter" 
            class="w-10 bg-slate-50 dark:bg-slate-900 border-r border-gray-300 dark:border-gray-700 text-slate-400 dark:text-slate-500 text-right pr-2.5 select-none py-3 overflow-hidden text-xs flex flex-col font-mono"
            style="line-height: 20px;"
          >
            <!-- Generated dynamically -->
          </div>
          
          <!-- Textarea Input Area -->
          <textarea 
            id="code-editor" 
            class="flex-1 bg-white dark:bg-[#0d1117] text-gray-900 dark:text-gray-300 px-3 py-3 resize-none focus:outline-none overflow-auto text-xs h-full font-mono whitespace-pre"
            style="line-height: 20px;"
            placeholder="Write your code solution here..."
            spellcheck="false"
            wrap="off"
          ></textarea>
        </div>

        <!-- Fullscreen Terminal Pane (only visible in fullscreen overlay mode) -->
        <div id="fullscreen-terminal-pane" class="hidden border-t border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-black h-[180px] flex-col font-mono relative">
          <!-- Fullscreen resize handle separator -->
          <div id="fullscreen-terminal-resizer" class="h-1 bg-gray-200 dark:bg-gray-700 hover:bg-brand-blue cursor-row-resize transition-colors w-full absolute top-0 left-0 z-20" title="Drag to Resize Terminal"></div>
          
          <div class="bg-gray-200 dark:bg-gray-800 border-b border-gray-300 dark:border-gray-700 px-4 py-1.5 flex items-center justify-between select-none h-[31px] mt-1">
            <span class="text-[10px] text-gray-800 dark:text-gray-300 uppercase font-bold tracking-wider">Terminal Output</span>
            <button 
              id="btn-clear-fullscreen-terminal" 
              class="text-[9px] px-2 py-0.5 border border-gray-300 dark:border-gray-600 bg-white dark:bg-slate-800 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-800 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white rounded transition-colors cursor-pointer"
            >
              Clear
            </button>
          </div>
          <div 
            id="fullscreen-terminal-content" 
            class="flex-1 p-3 text-sm font-mono overflow-y-auto whitespace-pre-wrap select-text leading-tight bg-gray-50 dark:bg-black text-gray-800 dark:text-gray-300"
          >
            <!-- Synced content -->
          </div>
        </div>
      </div>

      <!-- Execution Panel: Run Code trigger & Output Console -->
      <div class="flex flex-col space-y-3">
        <div class="flex items-center justify-between select-none">
          <div class="flex items-center gap-3">
            <!-- Glowing Run Button -->
            <button 
              id="btn-run-code"
              class="relative h-11 px-6 rounded-md bg-brand-blue border border-brand-blue-hover text-white font-medium hover:bg-brand-blue-hover hover:shadow-[0_0_15px_rgba(0,112,243,0.4)] active:scale-[0.98] transition-all cursor-pointer flex items-center justify-center gap-2 overflow-hidden"
            >
              <span id="btn-run-icon">▶</span>
              <span id="btn-run-text" class="font-mono text-xs tracking-wider font-bold">RUN CODE</span>
              <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full animate-shimmer pointer-events-none"></span>
            </button>

            <!-- Export Assignment Button -->
            <button 
              id="btn-export-assignment"
              class="relative h-11 px-4 rounded-md border border-slate-300 dark:border-slate-700 bg-white hover:bg-slate-50 dark:bg-slate-900 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-200 font-mono text-xs font-bold active:scale-[0.98] transition-all cursor-pointer flex items-center justify-center gap-2 overflow-hidden shadow-sm"
              title="Export assignment report"
            >
              <span>📸</span>
              <span>Export Assignment</span>
            </button>
          </div>
          
          <span class="text-[9px] text-brand-text-dim font-mono tracking-wide uppercase">
            Powered by Wandbox Sandbox API
          </span>
        </div>

        <!-- Resizer Separator -->
        <div id="normal-terminal-resizer" class="h-1 bg-gray-200 dark:bg-gray-700 hover:bg-brand-blue cursor-row-resize transition-colors w-full rounded-t-lg" title="Drag to Resize Terminal"></div>

        <!-- Terminal Output Div -->
        <div id="normal-terminal-container" class="border-x border-b border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-black rounded-b-xl overflow-hidden flex flex-col h-[200px] shadow-lg">
          <!-- Terminal Header -->
          <div class="bg-gray-200 dark:bg-gray-800 border-b border-gray-300 dark:border-gray-700 px-4 py-2 flex items-center justify-between select-none">
            <div class="flex items-center space-x-1.5">
              <!-- Console lights decoration -->
              <span class="w-2.5 h-2.5 rounded-full bg-[#ea4335]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#fbbc05]"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[#34a853]"></span>
              <span class="text-[10px] font-mono text-gray-800 dark:text-gray-300 ml-3 uppercase font-bold tracking-wider">Console Output</span>
            </div>
            
            <button 
              id="btn-clear-terminal" 
              class="text-[10px] px-2 py-0.5 border border-gray-300 dark:border-gray-600 bg-white dark:bg-slate-800 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-800 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white rounded font-mono transition-colors cursor-pointer"
            >
              Clear
            </button>
          </div>
          <!-- Output logs viewport -->
          <div 
            id="terminal-content" 
            class="flex-1 p-4 font-mono text-sm overflow-y-auto whitespace-pre-wrap leading-tight select-text bg-gray-50 dark:bg-black text-gray-800 dark:text-gray-300"
          >
            <span class="text-gray-400 dark:text-gray-500">// Click "Run Code" above to execute and check your solution.</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Panel: Dynamic AI Tutor Dashboard -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full mt-2">
    <!-- Logic Breakdown -->
    <div class="border border-slate-200 dark:border-slate-800 bg-white dark:bg-brand-gray-dark/40 rounded-xl p-5 shadow-xl flex flex-col">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-400 flex items-center gap-1.5 border-b border-slate-200 dark:border-slate-800 pb-2 mb-3 select-none">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-blue dark:bg-brand-blue-neon"></span>
        Logic Breakdown
      </h3>
      <p id="tutor-breakdown" class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed font-mono flex-1 whitespace-pre-line">
        Select a lesson to see syntax explanations.
      </p>
    </div>
    
    <!-- Real-Life Analogy -->
    <div class="border border-slate-200 dark:border-slate-800 bg-white dark:bg-brand-gray-dark/40 rounded-xl p-5 shadow-xl flex flex-col">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-400 flex items-center gap-1.5 border-b border-slate-200 dark:border-slate-800 pb-2 mb-3 select-none">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-blue dark:bg-brand-blue-neon"></span>
        Real-Life Analogy
      </h3>
      <p id="tutor-analogy" class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed flex-1">
        Select a lesson to see context analogies.
      </p>
    </div>
    
    <!-- Fix My Bug / Smart Debugger -->
    <div id="tutor-bug-card" class="border border-slate-200 dark:border-slate-800 bg-white dark:bg-brand-gray-dark/40 rounded-xl p-5 shadow-xl flex flex-col transition-all duration-300">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-400 flex items-center gap-1.5 border-b border-slate-200 dark:border-slate-800 pb-2 mb-3 select-none" id="tutor-bug-header">
        <span class="w-1.5 h-1.5 rounded-full bg-slate-400 dark:bg-brand-text-dim" id="tutor-bug-dot"></span>
        Smart Debugger
      </h3>
      <div id="tutor-bug-content" class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed flex-1">
        <p class="italic text-slate-400 dark:text-slate-500">No errors detected. Write code and run it!</p>
      </div>
    </div>
  </div>
</div>

<!-- Export Assignment Modal -->
<div id="export-modal" class="fixed inset-0 z-[300] hidden items-center justify-center bg-black/60 backdrop-blur-sm transition-all duration-300">
  <div id="export-modal-panel" class="w-full max-w-md p-6 bg-white dark:bg-[#151b23] border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl mx-4 transform transition-all duration-300 scale-95 opacity-0">
    <div class="flex items-center justify-between pb-3 border-b border-slate-100 dark:border-slate-800/80 mb-4">
      <h3 class="text-sm font-mono font-bold uppercase tracking-wider text-slate-800 dark:text-slate-100 flex items-center gap-2">
        <span>📸</span> Export Assignment Info
      </h3>
      <button id="btn-close-export-modal" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 cursor-pointer focus:outline-none transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <form id="export-form" class="space-y-4 font-mono text-xs">
      <div class="space-y-1.5">
        <label for="export-student-name" class="block text-[10px] uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400">Student Name</label>
        <input 
          type="text" 
          id="export-student-name" 
          required 
          placeholder="e.g., Rishabh Dev"
          class="w-full px-3 py-2 bg-slate-50 dark:bg-black/60 border border-slate-200 dark:border-gray-800 rounded-lg text-slate-800 dark:text-slate-200 focus:outline-none focus:border-brand-blue"
        />
      </div>
      
      <div class="space-y-1.5">
        <label for="export-student-roll" class="block text-[10px] uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400">Roll Number</label>
        <input 
          type="text" 
          id="export-student-roll" 
          required 
          placeholder="e.g., CS-2026-89"
          class="w-full px-3 py-2 bg-slate-50 dark:bg-black/60 border border-slate-200 dark:border-gray-800 rounded-lg text-slate-800 dark:text-slate-200 focus:outline-none focus:border-brand-blue"
        />
      </div>

      <div class="pt-2 flex justify-end gap-3">
        <button 
          type="button" 
          id="btn-cancel-export"
          class="px-4 py-2 bg-slate-100 hover:bg-slate-200 dark:bg-[#21262d] dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-lg font-bold cursor-pointer transition-colors"
        >
          Cancel
        </button>
        <button 
          type="submit" 
          id="btn-generate-image"
          class="px-4 py-2 bg-brand-blue hover:bg-brand-blue-hover text-white rounded-lg font-bold cursor-pointer transition-all flex items-center gap-1.5"
        >
          <span id="btn-generate-text">Generate Image</span>
        </button>
      </div>
    </form>
  </div>
</div>

<style>
  /* Shimmer glowing transition overlay */
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
  .animate-shimmer {
    animation: shimmer 2.5s infinite;
  }

  /* Native CSS Toggle expand/collapse icon based on editor-fullscreen class */
  #btn-toggle-fullscreen #collapse-icon {
    display: none !important;
  }
  #btn-toggle-fullscreen #expand-icon {
    display: block !important;
  }
  :global(.editor-fullscreen) #btn-toggle-fullscreen #collapse-icon {
    display: block !important;
  }
  :global(.editor-fullscreen) #btn-toggle-fullscreen #expand-icon {
    display: none !important;
  }

  /* Fullscreen editor layout styles mapping */
  :global(.editor-fullscreen) {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    z-index: 200 !important;
    border-radius: 0 !important;
    padding: 12px !important;
    transition: background-color 0.2s ease;
  }
  :global(.light .editor-fullscreen) {
    background-color: #f1f5f9 !important;
  }
  :global(.dark .editor-fullscreen) {
    background-color: #0b0c0f !important;
  }
</style>

<script>
  // Expanded step-by-step roadmap lessons structure containing 10 sub-challenges each (40 total)
  const lessons = [
    {
      id: 0,
      title: "Hello World",
      shortTitle: "Hello World",
      challenges: [
        {
          subId: 0,
          title: "Print Hello World",
          instruction: "Write a program that outputs the exact text 'Hello, World!' to the screen.",
          successCriteria: "output contains 'Hello, World!'",
          validate: (output) => /Hello,\s*World/i.test(output),
          templates: {
            python: `print("Hello, World!")`,
            c: `#include <stdio.h>\n\nint main() {\n    printf("Hello, World!\\n");\n    return 0;\n}`,
            cpp: `#include <iostream>\n\nint main() {\n    std::cout << "Hello, World!" << std::endl;\n    return 0;\n}`
          },
          breakdown: {
            python: "In Python, the `print()` function displays text. Text values must be wrapped inside double or single quotes.",
            c: "In C, `#include <stdio.h>` imports standard input/output declarations. `printf()` outputs strings. Semicolons `;` terminate statements, and `main()` must return an integer `0`.",
            cpp: "In C++, `#include <iostream>` imports stream output utilities. `std::cout` represents the output, and `<<` streams characters into it. `std::endl` adds a newline and flushes buffers."
          },
          analogy: {
            python: "Like writing 'Hello, World!' on a post-it note and sticking it on the board. One simple step.",
            c: "Like writing a formal letter. You must include the formal letterhead (#include), declare the sender's address (int main), write the body of the message (printf), sign off (return 0), and seal it with a stamp (;).",
            cpp: "Similar to C, but using a conveyor belt (<<) to push your words down a pipeline into a large megaphone (std::cout)."
          }
        },
        {
          subId: 1,
          title: "Print Welcome Message",
          instruction: "Write a program that outputs the exact text 'Welcome, Developer!' to the screen.",
          successCriteria: "output contains 'Welcome, Developer!'",
          validate: (output) => /Welcome,\s*Developer/i.test(output),
          templates: {
            python: `print("Welcome, Developer!")`,
            c: `#include <stdio.h>\n\nint main() {\n    printf("Welcome, Developer!\\n");\n    return 0;\n}`,
            cpp: `#include <iostream>\n\nint main() {\n    std::cout << "Welcome, Developer!" << std::endl;\n    return 0;\n}`
          },
          breakdown: {
            python: "Outputs the customized string 'Welcome, Developer!' using Python's standard `print()` call.",
            c: "Outputs the welcome string in C using `printf(\"Welcome, Developer!\\n\");`.",
            cpp: "Streams the string 'Welcome, Developer!' into standard output `std::cout`."
          },
          analogy: {
            python: "Like hanging a customized 'Welcome' sign at the entrance door.",
            c: "A formal lobby reception screen announcement.",
            cpp: "Pushing a custom welcome marquee down the streaming conveyor belt."
          }
        },
        {
          subId: 2,
          title: "Learn Code Academy",
          instruction: "Write a program that outputs 'Learn Code Academy' to the screen.",
          successCriteria: "output contains 'Learn Code Academy'",
          validate: (output) => /Learn\s*Code\s*Academy/i.test(output),
          templates: {

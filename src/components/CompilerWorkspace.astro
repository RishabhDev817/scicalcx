  // Escape HTML tags
  function escapeHTML(str) {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  // Error diagnostic translator
  function translateError(stderr, language) {
    if (!stderr) return null;
    
    let explanation = "";
    let solution = "";
    
    if (language === 'python') {
      if (stderr.includes("IndentationError")) {
        explanation = "Indentation Mismatch (IndentationError)";
        solution = "Python uses spaces or tabs to organize blocks. Make sure statements inside loops or conditionally matched blocks are indented forward (usually 4 spaces) consistently compared to their parent statements.";
      } else if (stderr.includes("SyntaxError")) {
        explanation = "Structural Syntax Error (SyntaxError)";
        solution = "Python parser found structural errors. Confirm that your loops or 'if' branching blocks end with a colon (:), and check for unclosed quotes or parentheses.";
      } else if (stderr.includes("NameError")) {
        const match = stderr.match(/name '(\w+)' is not defined/);
        const name = match ? match[1] : "variable";
        explanation = `Undefined Variable (NameError): '${name}'`;
        solution = `You are trying to read or call '${name}' before creating it. Check for spelling typos, or initialize it first.`;
      } else if (stderr.includes("TypeError")) {
        explanation = "Incompatible Value Operation (TypeError)";
        solution = "You tried performing operations across conflicting datatypes (e.g. adding text strings to integers). Convert values with int() or str() first.";
      } else {
        explanation = "Script Runtime Crash";
        solution = "Check the traceback logs. Ensure variables are typed correctly and confirm operations are mathematically correct.";
      }
    } else {
      if (stderr.includes("expected ';'") || stderr.includes("expected ';' before")) {
        explanation = "Missing Semicolon (';')";
        solution = "Statements in C and C++ must terminate with a semicolon. Inspect the exact line referenced in the compiler output, or check the line right above it.";
      } else if (stderr.includes("undeclared identifier") || stderr.includes("not declared in this scope")) {
        explanation = "Undeclared Reference Variable";
        solution = "You referenced a variable without establishing its data type. Ensure you declare variables with explicit types (e.g. `int num = 7;`).";
      } else if (stderr.includes("expected '}'") || stderr.includes("expected '{'")) {
        explanation = "Unbalanced Curly Braces ('{}')";
        solution = "Compiler blocks do not match. Check that every opening brace '{' has a corresponding closing brace '}'.";
      } else if (stderr.includes("No such file or directory")) {
        explanation = "Header Library Not Found";
        solution = "Verify the spelling of library imports. Use standard inclusions: `#include <stdio.h>` for C, or `#include <iostream>` for C++.";
      } else if (stderr.includes("main must return int")) {
        explanation = "Invalid main Signature";
        solution = "The main starting method must yield an integer type. Declare it as `int main()` rather than `void main()`, and ensure it ends with `return 0;`.";
      } else {
        explanation = "Compilation Diagnostics Alert";
        solution = "Check logs above. Look out for misplaced parameters, typos in keywords, or parentheses mismatches.";
      }
    }
    
    return { explanation, solution };
  }


---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  activeTab?: 'scientific' | 'matrix' | 'statistics' | 'programming' | 'calculus' | 'graphing';
}

const {
  title = 'SciCalcX | Premium Online Scientific Calculator',
  description = 'High-performance online scientific calculator addressing common engineering issues. Real-time token parsing, input sanitization, multi-line viewports, precision float math, and Base-N views.',
  activeTab = 'scientific',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XSYVYWTGTS"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-XSYVYWTGTS');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="SciCalcX" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://scicalcx.com/" />
    <meta property="og:image" content="https://scicalcx.com/og-image.png" />
    <meta property="og:site_name" content="SciCalcX" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://scicalcx.com/og-image.png" />
    <meta name="theme-color" content="#000000" />
    <script is:inline>
      // Run theme initialization before HTML paints to avoid layout flashing
      (function() {
        const theme = localStorage.getItem('theme') || 'dark';
        if (theme === 'light') {
          document.documentElement.classList.add('light');
        } else {
          document.documentElement.classList.remove('light');
        }
      })();
    </script>
  </head>
  <body class="bg-brand-black text-brand-text min-h-screen flex flex-col font-sans selection:bg-brand-blue selection:text-white">
    <!-- Atmospheric Mesh Grid Background -->
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,#0f0f0f_1px,transparent_1px),linear-gradient(to_bottom,#0f0f0f_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-70"></div>

    <!-- Sticky Header -->
    <header class="sticky top-0 z-40 bg-brand-black/80 backdrop-blur-md border-b border-brand-border h-14 flex items-center justify-between px-3 sm:px-6">
      <div class="flex items-center space-x-3 sm:space-x-6">
        <a href="/" class="flex items-center space-x-2 group focus:outline-none">
          <span class="text-lg sm:text-xl font-bold tracking-tight text-brand-text flex items-center gap-1.5">
            <span class="text-brand-blue transition-transform group-hover:scale-110">▲</span>
            SciCalc<span class="text-brand-blue-neon">X</span>
          </span>
        </a>
        <nav class="hidden md:flex items-center space-x-1">
          <a
            href="/"
            class={`px-2.5 py-1.5 text-[10px] sm:text-xs font-medium rounded-md transition-colors ${
              activeTab === 'scientific'
                ? 'bg-brand-gray-light text-white border border-brand-border'
                : 'text-brand-text-muted hover:text-white hover:bg-brand-gray-hover/50'
            }`}
          >
            Scientific
          </a>
          <a
            href="/matrix"
            class={`px-2.5 py-1.5 text-[10px] sm:text-xs font-medium rounded-md transition-colors ${
              activeTab === 'matrix'
                ? 'bg-brand-gray-light text-white border border-brand-border'
                : 'text-brand-text-muted hover:text-white hover:bg-brand-gray-hover/50'
            }`}
          >
            Matrix
          </a>
          <a
            href="/calculus"
            class={`px-2.5 py-1.5 text-[10px] sm:text-xs font-medium rounded-md transition-colors ${
              activeTab === 'calculus'
                ? 'bg-brand-gray-light text-white border border-brand-border'
                : 'text-brand-text-muted hover:text-white hover:bg-brand-gray-hover/50'
            }`}
          >
            Calculus
          </a>
          <a
            href="/graphing"
            class={`px-2.5 py-1.5 text-[10px] sm:text-xs font-medium rounded-md transition-colors ${
              activeTab === 'graphing'
                ? 'bg-brand-gray-light text-white border border-brand-border'
                : 'text-brand-text-muted hover:text-white hover:bg-brand-gray-hover/50'
            }`}
          >
            Graphing
          </a>
          <a
            href="/programming"
            class={`px-2.5 py-1.5 text-[10px] sm:text-xs font-medium rounded-md transition-colors ${
              activeTab === 'programming'
                ? 'bg-brand-gray-light text-white border border-brand-border'
                : 'text-brand-text-muted hover:text-white hover:bg-brand-gray-hover/50'
            }`}
          >
            Programmer
          </a>
        </nav>
      </div>

      <div class="flex items-center space-x-2">
        <!-- Theme Toggle Button -->
        <button
          id="theme-toggle"
          class="flex items-center justify-center p-1.5 rounded-md text-brand-text-muted hover:text-white border border-brand-border bg-brand-gray-light/60 hover:bg-brand-gray-hover hover:border-brand-border-hover transition-all cursor-pointer focus:outline-none focus:ring-1 focus:ring-brand-blue"
          aria-label="Toggle light/dark theme"
        >
          <!-- Sun Icon (Visible in dark mode) -->
          <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
          </svg>
          <!-- Moon Icon (Visible in light mode) -->
          <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- History Sidebar Toggle -->
        <button
          id="history-toggle"
          class="flex items-center space-x-1.5 px-2.5 py-1.5 rounded-md text-xs font-medium border border-brand-border bg-brand-gray-light/60 hover:bg-brand-gray-hover hover:border-brand-border-hover text-brand-text-muted hover:text-white transition-all cursor-pointer focus:outline-none focus:ring-1 focus:ring-brand-blue"
          aria-label="Toggle history sidebar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="hidden sm:inline">History</span>
        </button>
      </div>
    </header>

    <!-- Mobile Scrollable Sub-Nav -->
    <div class="md:hidden border-b border-brand-border bg-brand-black/90 py-2 px-3 flex items-center space-x-1.5 overflow-x-auto scrollbar-none">
      <a
        href="/"
        class={`shrink-0 whitespace-nowrap px-2.5 py-1 rounded text-[10px] font-medium transition-colors ${
          activeTab === 'scientific' ? 'bg-brand-gray-light text-white border border-brand-border' : 'text-brand-text-muted'
        }`}
      >
        Scientific
      </a>
      <a
        href="/matrix"
        class={`shrink-0 whitespace-nowrap px-2.5 py-1 rounded text-[10px] font-medium transition-colors ${
          activeTab === 'matrix' ? 'bg-brand-gray-light text-white border border-brand-border' : 'text-brand-text-muted'
        }`}
      >
        Matrix
      </a>
      <a
        href="/calculus"
        class={`shrink-0 whitespace-nowrap px-2.5 py-1 rounded text-[10px] font-medium transition-colors ${
          activeTab === 'calculus' ? 'bg-brand-gray-light text-white border border-brand-border' : 'text-brand-text-muted'
        }`}
      >
        Calculus
      </a>
      <a
        href="/graphing"
        class={`shrink-0 whitespace-nowrap px-2.5 py-1 rounded text-[10px] font-medium transition-colors ${
          activeTab === 'graphing' ? 'bg-brand-gray-light text-white border border-brand-border' : 'text-brand-text-muted'
        }`}
      >
        Graphing
      </a>
      <a
        href="/programming"
        class={`shrink-0 whitespace-nowrap px-2.5 py-1 rounded text-[10px] font-medium transition-colors ${
          activeTab === 'programming' ? 'bg-brand-gray-light text-white border border-brand-border' : 'text-brand-text-muted'
        }`}
      >
        Programmer
      </a>
    </div>

    <!-- Main Workspace Layout -->
    <div class="flex-1 flex relative overflow-hidden">
      <!-- Main Content Area -->
      <main class="flex-1 flex flex-col items-center justify-start p-3 sm:p-4 lg:p-6 overflow-y-auto max-w-5xl mx-auto w-full">
        <slot />
      </main>

      <!-- History Sidebar -->
      <aside
        id="history-sidebar"
        class="fixed inset-y-14 right-0 w-full sm:w-80 bg-brand-gray-dark border-l border-brand-border transform translate-x-full transition-transform duration-300 ease-in-out z-30 flex flex-col shadow-2xl md:shadow-none"
      >
        <div class="p-4 border-b border-brand-border flex items-center justify-between">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-brand-text-muted flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-blue-neon"></span>
            Calculation History
          </h2>
          <button
            id="clear-history"
            class="text-[10px] text-brand-text-dim hover:text-red-500 font-mono transition-colors uppercase cursor-pointer focus:outline-none"
          >
            [ Clear All ]
          </button>
        </div>

        <!-- History Content -->
        <div id="history-list" class="flex-1 overflow-y-auto p-4 space-y-3 font-mono text-xs">
          <!-- Populated by client JS -->
          <div class="text-brand-text-dim text-center py-8">No calculations recorded.</div>
        </div>
      </aside>
    </div>

    <!-- Vercel Style Footer -->
    <footer class="border-t border-brand-border bg-brand-black py-6 px-3 sm:px-6 text-center text-xs sm:text-sm text-brand-text-dim">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-3">
        <div>
          &copy; {new Date().getFullYear()} SciCalcX. Open-source scientific computational system.
        </div>
        <div class="flex flex-wrap justify-center space-x-3 sm:space-x-4">
          <a href="/about" class="hover:text-brand-text transition-colors">About Us</a>
          <span>&bull;</span>
          <a href="/contact" class="hover:text-brand-text transition-colors">Contact Us</a>
          <span>&bull;</span>
          <a href="/terms" class="hover:text-brand-text transition-colors">Terms &amp; Conditions</a>
          <span>&bull;</span>
          <a href="/privacy" class="hover:text-brand-text transition-colors">Privacy Policy</a>
        </div>
      </div>
    </footer>

    <!-- Client Script for UI Controls -->
    <script>
      // Sidebar Toggle Logic
      const historyToggle = document.getElementById('history-toggle');
      const historySidebar = document.getElementById('history-sidebar');
      const historyList = document.getElementById('history-list');
      const clearHistoryBtn = document.getElementById('clear-history');

      let isSidebarOpen = false;

      // Read history from state
      function getHistory() {
        try {
          return JSON.parse(localStorage.getItem('scicalcx_history') || '[]');
        } catch {
          return [];
        }
      }

      // Add to history
      function saveHistory(expr, result, mode = 'scientific') {
        const history = getHistory();
        history.unshift({ id: Date.now(), expr, result, mode, time: new Date().toLocaleTimeString() });
        localStorage.setItem('scicalcx_history', JSON.stringify(history.slice(0, 50))); // Cap at 50
        renderHistory();
      }

      // Render history list
      function renderHistory() {
        if (!historyList) return;
        const history = getHistory();
        
        if (history.length === 0) {
          historyList.innerHTML = `<div class="text-brand-text-dim text-center py-8">No calculations recorded.</div>`;
          return;
        }

        historyList.innerHTML = history
          .map(
            (item) => `
            <div class="p-2.5 rounded border border-brand-border bg-brand-gray-light/40 hover:bg-brand-gray-hover/60 cursor-pointer group transition-all relative overflow-hidden" 
                 data-expr="${encodeURIComponent(item.expr)}"
                 data-mode="${item.mode}">
              <div class="absolute right-1.5 top-1 text-[8px] text-brand-text-dim font-sans uppercase bg-brand-black px-1.5 rounded border border-brand-border">
                ${item.mode}
              </div>
              <div class="text-brand-text-muted group-hover:text-brand-blue-neon transition-colors break-words pr-8 mt-1 font-mono">${item.expr}</div>
              <div class="text-white font-semibold text-right mt-1.5 border-t border-brand-border/30 pt-1 text-sm break-all font-mono">= ${item.result}</div>
            </div>
          `
          )
          .join('');

        // Bind clicks to history load
        historyList.querySelectorAll('[data-expr]').forEach((el) => {
          el.addEventListener('click', (e) => {
            const rawExpr = el.getAttribute('data-expr');
            const expr = decodeURIComponent(rawExpr || '');
            const mode = el.getAttribute('data-mode');
            
            // Dispatch dynamic event to load expression into active calculator page
            window.dispatchEvent(
              new CustomEvent('load-expression', {
                detail: { expression: expr, mode: mode }
              })
            );
          });
        });
      }

      // Toggle functionality
      function toggleSidebar() {
        isSidebarOpen = !isSidebarOpen;
        if (isSidebarOpen) {
          historySidebar?.classList.remove('translate-x-full');
          historyToggle?.classList.add('border-brand-blue', 'text-white');
        } else {
          historySidebar?.classList.add('translate-x-full');
          historyToggle?.classList.remove('border-brand-blue', 'text-white');
        }
      }

      historyToggle?.addEventListener('click', toggleSidebar);

      clearHistoryBtn?.addEventListener('click', () => {
        if (confirm('Clear calculation history?')) {
          localStorage.removeItem('scicalcx_history');
          renderHistory();
        }
      });

      // Listen to new calculations added from calculators
      window.addEventListener('add-history', (e: any) => {
        const { expr, result, mode } = e.detail;
        saveHistory(expr, result, mode);
      });

      // Theme Toggle Logic
      const themeToggle = document.getElementById('theme-toggle');
      const sunIcon = document.getElementById('sun-icon');
      const moonIcon = document.getElementById('moon-icon');

      function updateThemeUI() {
        const isLight = document.documentElement.classList.contains('light');
        if (isLight) {
          sunIcon?.classList.add('hidden');
          moonIcon?.classList.remove('hidden');
        } else {
          sunIcon?.classList.remove('hidden');
          moonIcon?.classList.add('hidden');
        }
      }

      themeToggle?.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        updateThemeUI();
        window.dispatchEvent(new CustomEvent('theme-changed', { detail: { theme: isLight ? 'light' : 'dark' } }));
      });

      // Initial theme icon setup
      updateThemeUI();

      // Initial render
      renderHistory();
    </script>
  </body>
</html>
